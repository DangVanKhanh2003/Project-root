{%- set base = i18nBase[lang] or i18nBase['en'] -%}
{%- set langPrefix = '' if (lang == 'en' or not lang) else '/' + lang -%}
{%- set pageSlug = '' if pageKey == 'index' else pageKey -%}

<!-- HEADER -->
<header class="site-header">
    <div class="container">
        <div class="header-inner">
            <a href="{{ langPrefix }}/" class="header-logo" aria-label="EzConv.pro home">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 50" fill="none" aria-hidden="true"
                    focusable="false">
                    <path d="M 4 23 v 4 M 10 20 v 10 M 16 15 v 20 M 22 9 v 32 M 28 15 v 20 M 34 17 v 16 M 40 10 v 30 M 46 4 v 42 M 52 2 v 46 M 58 11 v 28 M 64 16 v 18 M 70 12 v 26 M 76 18 v 14 M 82 17 v 16 M 88 21 v 8"
                        stroke="#C65D3B" stroke-width="3.5" stroke-linecap="round" fill="none" />
                </svg>
                <span class="header-logo-text">EzConv.pro</span>
            </a>
            <nav class="header-nav" aria-label="Primary">
                <div class="license-menu" data-license-button hidden aria-hidden="true">
                    <button type="button" class="license-button" data-license-trigger data-license-default-label="{{ base.nav.license or 'License' }}" aria-haspopup="true" aria-expanded="false" aria-label="License options">
                        <span class="license-icon" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12.65 10C11.83 7.67 9.61 6 7 6c-3.31 0-6 2.69-6 6s2.69 6 6 6c2.61 0 4.83-1.67 5.65-4H17v4h4v-4h2v-4H12.65zM7 14c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z"></path>
                            </svg>
                        </span>
                        <span>{{ base.nav.license or 'License' }}</span>
                    </button>
                    <div class="license-dropdown" data-license-dropdown>
                        <a href="/license" class="license-dropdown-item" data-license-action="add">
                            <span class="license-dropdown-icon" aria-hidden="true">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M19 11h-6V5h-2v6H5v2h6v6h2v-6h6z"></path>
                                </svg>
                            </span>
                            <span>{{ base.nav.addLicense or 'Add License Key' }}</span>
                        </a>
                        <a href="https://ytmp3-supporter.ytmp3.gg/reset/" target="_blank" rel="noopener nofollow noreferrer" class="license-dropdown-item" data-license-action="reset">
                            <span class="license-dropdown-icon" aria-hidden="true">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M13 3a9 9 0 0 0-9 9H1l4 4 4-4H6a7 7 0 1 1 2.05 4.95l-1.42 1.42A9 9 0 1 0 13 3z"></path>
                                </svg>
                            </span>
                            <span>{{ base.nav.resetLicense or 'Reset License Key' }}</span>
                        </a>
                        <a href="https://ko-fi.com/s/fa5c2b2a93" target="_blank" rel="noopener nofollow noreferrer" class="license-dropdown-item" data-license-action="get">
                            <span class="license-dropdown-icon" aria-hidden="true">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M20 6h-2.17A3.001 3.001 0 0 0 12 4.76 3.001 3.001 0 0 0 6.17 6H4a2 2 0 0 0-2 2v3h1v9a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-9h1V8a2 2 0 0 0-2-2zM15 4a1 1 0 1 1 0 2h-2V5a1 1 0 0 1 1-1h1zM9 4h1a1 1 0 0 1 1 1v1H9a1 1 0 1 1 0-2zm10 6h-6v10h6V10zm-8 10V10H5v10h6zm9-12v1H4V8h16z"></path>
                                </svg>
                            </span>
                            <span>{{ base.nav.getLicense or 'Get License Key' }}</span>
                        </a>
                    </div>
                </div>
                <div class="lang-selector">
                    <button class="lang-button" type="button" aria-label="{{ base.langSelector.buttonLabel }}">
                        <span>{{ base.langSelector.buttonText }}</span>
                        <svg class="lang-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2">
                            <path d="M6 9l6 6 6-6" />
                        </svg>
                    </button>
                    <div class="lang-dropdown" role="menu" aria-label="Languages">
                        <div class="lang-dropdown-scroll">
                            {%- set singleLangPages = ['about', 'contact', 'dmca', 'faq', 'policy', 'terms-of-use'] -%}
                            {%- for langItem in site.languages %}
                            {%- if langItem.isDefault %}
                                {%- set langUrl = '/' if pageSlug == '' else '/' + pageSlug %}
                            {%- else %}
                                {%- if pageKey in singleLangPages %}
                                    {%- set langUrl = '/' + langItem.code + '/' %}
                                {%- else %}
                                    {%- set langUrl = '/' + langItem.code + '/' if pageSlug == '' else '/' + langItem.code + '/' + pageSlug %}
                                {%- endif %}
                            {%- endif %}
                            <a href="{{ langUrl }}" class="lang-option{% if langItem.code == lang %} active{% endif %}" role="menuitem">
                                <img class="lang-flag" src="/assest/flat-svg/{{ langItem.flag }}" alt="{{ langItem.name }}" aria-hidden="true"
                                    loading="lazy" width="18" height="14">
                                <span>{{ langItem.name }}</span>
                            </a>
                            {%- endfor %}
                        </div>
                    </div>
                </div>
            </nav>
            <button class="theme-toggle-btn theme-toggle-btn--header" type="button" aria-label="Toggle theme">
                <svg class="theme-icon theme-icon--sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="5"/>
                    <line x1="12" y1="1" x2="12" y2="3"/>
                    <line x1="12" y1="21" x2="12" y2="23"/>
                    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                    <line x1="1" y1="12" x2="3" y2="12"/>
                    <line x1="21" y1="12" x2="23" y2="12"/>
                    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                </svg>
                <svg class="theme-icon theme-icon--moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                </svg>
            </button>
            <button id="mobile-menu-btn" class="mobile-menu-btn" type="button" aria-label="Open menu">
                <span class="mobile-menu-bars" aria-hidden="true"></span>
            </button>
        </div>
    </div>
</header>

<!-- MOBILE DRAWER -->
<div id="mobile-drawer" class="mobile-drawer" hidden>
    <div id="mobile-drawer-content" class="drawer-content" role="dialog" aria-modal="true" aria-label="Mobile menu">
        <div class="drawer-header">
            <a href="{{ langPrefix }}/" class="drawer-logo" aria-label="EzConv.pro home">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 50" fill="none" aria-hidden="true"
                    focusable="false">
                    <path d="M 4 23 v 4 M 10 20 v 10 M 16 15 v 20 M 22 9 v 32 M 28 15 v 20 M 34 17 v 16 M 40 10 v 30 M 46 4 v 42 M 52 2 v 46 M 58 11 v 28 M 64 16 v 18 M 70 12 v 26 M 76 18 v 14 M 82 17 v 16 M 88 21 v 8"
                        stroke="#C65D3B" stroke-width="3.5" stroke-linecap="round" fill="none" />
                </svg>
                <span class="drawer-logo-text">{{ base.drawer.logoText }}</span>
            </a>
            <button id="close-drawer-btn" class="drawer-close" type="button" aria-label="Close menu">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
        <div class="drawer-scroll">
            <nav class="drawer-nav" aria-label="Mobile">
                <a href="{{ langPrefix }}/" class="drawer-link">{{ base.drawer.links.home }}</a>

                <a href="/about" class="drawer-link">{{ base.drawer.links.about }}</a>
                <a href="/faq" class="drawer-link">{{ base.drawer.links.faq }}</a>
                <a href="/contact" class="drawer-link">{{ base.drawer.links.contact }}</a>
                <a href="/terms-of-use" class="drawer-link">{{ base.drawer.links.terms }}</a>
                <a href="/policy" class="drawer-link">{{ base.drawer.links.privacy }}</a>
                <a href="/dmca" class="drawer-link">{{ base.drawer.links.dmca }}</a>
                <div class="drawer-license-menu" data-license-button hidden aria-hidden="true">
                    <button type="button" class="drawer-license-trigger" data-license-trigger data-license-default-label="{{ base.nav.license or 'License' }}" aria-haspopup="true" aria-expanded="false" aria-label="License options">
                        <span class="license-icon" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12.65 10C11.83 7.67 9.61 6 7 6c-3.31 0-6 2.69-6 6s2.69 6 6 6c2.61 0 4.83-1.67 5.65-4H17v4h4v-4h2v-4H12.65zM7 14c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z"></path>
                            </svg>
                        </span>
                        <span>{{ base.nav.license or 'License' }}</span>
                    </button>
                    <div class="license-dropdown drawer-license-actions">
                        <a href="/license" class="license-dropdown-item drawer-sublink drawer-license-link" data-license-action="add">
                            <span class="license-dropdown-icon" aria-hidden="true">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M19 11h-6V5h-2v6H5v2h6v6h2v-6h6z"></path>
                                </svg>
                            </span>
                            <span>{{ base.nav.addLicense or 'Add License Key' }}</span>
                        </a>
                        <a href="https://ytmp3-supporter.ytmp3.gg/reset/" target="_blank" rel="noopener nofollow noreferrer" class="license-dropdown-item drawer-sublink drawer-license-link" data-license-action="reset">
                            <span class="license-dropdown-icon" aria-hidden="true">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M13 3a9 9 0 0 0-9 9H1l4 4 4-4H6a7 7 0 1 1 2.05 4.95l-1.42 1.42A9 9 0 1 0 13 3z"></path>
                                </svg>
                            </span>
                            <span>{{ base.nav.resetLicense or 'Reset License Key' }}</span>
                        </a>
                        <a href="https://ko-fi.com/s/fa5c2b2a93" target="_blank" rel="noopener nofollow noreferrer" class="license-dropdown-item drawer-sublink drawer-license-link" data-license-action="get">
                            <span class="license-dropdown-icon" aria-hidden="true">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M20 6h-2.17A3.001 3.001 0 0 0 12 4.76 3.001 3.001 0 0 0 6.17 6H4a2 2 0 0 0-2 2v3h1v9a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-9h1V8a2 2 0 0 0-2-2zM15 4a1 1 0 1 1 0 2h-2V5a1 1 0 0 1 1-1h1zM9 4h1a1 1 0 0 1 1 1v1H9a1 1 0 1 1 0-2zm10 6h-6v10h6V10zm-8 10V10H5v10h6zm9-12v1H4V8h16z"></path>
                                </svg>
                            </span>
                            <span>{{ base.nav.getLicense or 'Get License Key' }}</span>
                        </a>
                    </div>
                </div>
            </nav>
            <div class="drawer-lang-selector">
                <button class="drawer-lang-button" type="button" aria-label="Choose language">
                    <span>{{ base.langSelector.currentLangFull }}</span>
                    <svg class="lang-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <path d="M6 9l6 6 6-6" />
                    </svg>
                </button>
                <div class="drawer-lang-menu" role="menu" aria-label="Languages">
                    {%- set singleLangPages = ['about', 'contact', 'dmca', 'faq', 'policy', 'terms-of-use'] -%}
                    {%- for langItem in site.languages %}
                    {%- if langItem.isDefault %}
                        {%- set langUrl = '/' if pageSlug == '' else '/' + pageSlug %}
                    {%- else %}
                        {%- if pageKey in singleLangPages %}
                            {%- set langUrl = '/' + langItem.code + '/' %}
                        {%- else %}
                            {%- set langUrl = '/' + langItem.code + '/' if pageSlug == '' else '/' + langItem.code + '/' + pageSlug %}
                        {%- endif %}
                    {%- endif %}
                    <a href="{{ langUrl }}" class="drawer-sublink{% if langItem.code == lang %} active{% endif %}" role="menuitem">{{ langItem.name }}</a>
                    {%- endfor %}
                </div>
            </div>
            <button class="theme-toggle-btn theme-toggle-btn--drawer" type="button" aria-label="Toggle theme">
                <svg class="theme-icon theme-icon--sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="5"/>
                    <line x1="12" y1="1" x2="12" y2="3"/>
                    <line x1="12" y1="21" x2="12" y2="23"/>
                    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                    <line x1="1" y1="12" x2="3" y2="12"/>
                    <line x1="21" y1="12" x2="23" y2="12"/>
                    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                </svg>
                <svg class="theme-icon theme-icon--moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                </svg>
            </button>
        </div>
    </div>
</div>
