{%- set base = i18nBase[lang] or i18nBase['en'] -%}
{%- set langPrefix = '' if (lang == 'en' or not lang) else '/' + lang -%}
{%- set pageSlug = '' if pageKey == 'index' else pageKey -%}

<!-- HEADER -->
<header class="site-header">
    <div class="container">
        <div class="header-inner">
            <a href="{{ langPrefix }}/" class="header-logo" aria-label="EzConv.pro home">
                <svg id="wave-svg-1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 50" fill="none" aria-hidden="true" focusable="false" style="cursor:pointer"><style>.wave-line{transform-origin:center 25px;transform:scaleY(1)}.run-wave{animation:wave-run .5s ease-in-out forwards}@keyframes wave-run{0%,100%{transform:scaleY(1)}50%{transform:scaleY(1.5)}}</style><rect width="100" height="50" fill="transparent"/><g stroke="#C65D3B" stroke-width="3.5" stroke-linecap="round"><path class="wave-line" d="M 4 23 v 4"/><path class="wave-line" d="M 10 20 v 10"/><path class="wave-line" d="M 16 15 v 20"/><path class="wave-line" d="M 22 9 v 32"/><path class="wave-line" d="M 28 15 v 20"/><path class="wave-line" d="M 34 17 v 16"/><path class="wave-line" d="M 40 10 v 30"/><path class="wave-line" d="M 46 4 v 42"/><path class="wave-line" d="M 52 2 v 46"/><path class="wave-line" d="M 58 11 v 28"/><path class="wave-line" d="M 64 16 v 18"/><path class="wave-line" d="M 70 12 v 26"/><path class="wave-line" d="M 76 18 v 14"/><path class="wave-line" d="M 82 17 v 16"/><path class="wave-line" d="M 88 21 v 8"/></g></svg>
                <span class="header-logo-text">EzConv.pro</span>
            </a>
            <nav class="header-nav" aria-label="Primary">
                <div class="license-menu" data-license-button hidden aria-hidden="true">
