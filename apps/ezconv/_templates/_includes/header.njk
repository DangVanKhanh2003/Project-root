                        <span class="license-icon" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12.65 10C11.83 7.67 9.61 6 7 6c-3.31 0-6 2.69-6 6s2.69 6 6 6c2.61 0 4.83-1.67 5.65-4H17v4h4v-4h2v-4H12.65zM7 14c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z"></path>
                            </svg>
                        </span>
                        <span>{{ base.nav.license or 'License' }}</span>
                        <svg class="license-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                            <path d="M6 9l6 6 6-6" />
                        </svg>
                    </button>
                    <div class="license-dropdown" data-license-dropdown>
                        <div class="license-status-bar" data-license-status hidden
                            style="padding: 10px 14px; border-bottom: 1px solid var(--border-subtle); display: flex; flex-direction: column; gap: 4px;">
                            <div style="display: flex; justify-content: space-between; align-items: center;">
                                <span style="font-size: 0.8rem; color: var(--text-secondary);">Plan</span>
                                <strong data-license-plan-label style="font-size: 0.85rem; color: var(--text-heading);"></strong>
                            </div>
                            <div style="display: flex; justify-content: space-between; align-items: center;">
                                <span style="font-size: 0.8rem; color: var(--text-secondary);">Remaining</span>
                                <strong data-license-days-label style="font-size: 0.85rem; color: var(--brand);"></strong>
                            </div>
                        </div>
                        <a href="/license" class="license-dropdown-item" data-license-action="add">
                            <span class="license-dropdown-icon" aria-hidden="true">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M19 11h-6V5h-2v6H5v2h6v6h2v-6h6z"></path>
                                </svg>
                            </span>
                            <span>{{ base.nav.addLicense or 'Add License Key' }}</span>
                        </a>
                        <a href="https://ytmp3-supporter.ytmp3.gg/reset/" target="_blank" rel="noopener nofollow noreferrer" class="license-dropdown-item" data-license-action="reset">
                            <span class="license-dropdown-icon" aria-hidden="true">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M13 3a9 9 0 0 0-9 9H1l4 4 4-4H6a7 7 0 1 1 2.05 4.95l-1.42 1.42A9 9 0 1 0 13 3z"></path>
                                </svg>
                            </span>
                            <span>{{ base.nav.resetLicense or 'Reset License Key' }}</span>
                        </a>
