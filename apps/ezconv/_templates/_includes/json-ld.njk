{#- JSON-LD Structured Data for SEO (EEAT compliant) -#}
{%- set isHomePage = (pageKey == 'index') -%}
{%- set isRootHomePage = isHomePage and (langCode == 'en' or not langCode) -%}
{%- set hasHowTo = pageData.overview and pageData.overview.howTo and pageData.overview.howTo.steps -%}
{%- set hasFaqs = pageData.faqs and pageData.faqs.items -%}

{#- Build canonical URL -#}
{%- set cleanUrl = page.url | replace('/index.html', '/') | replace('.html', '') -%}
{%- set canonicalUrl = site.url + cleanUrl -%}
{#- @id uses canonicalUrl directly with #fragment (no extra / needed) -#}

<script type="application/ld+json">
{%- if isHomePage %}
{#- === HOMEPAGE === -#}
{
  "@context": "https://schema.org",
  "@graph": [
    {%- if isRootHomePage %}
    {
      "@type": "Organization",
      "@id": "{{ site.url }}/#organization",
      "name": "EzConv.pro",
      "url": "{{ site.url }}/",
      "logo": {
        "@type": "ImageObject",
        "url": "{{ site.url }}/logo.png"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer support",
        "email": "ezconv.pro@gmail.com"
      }
    },
    {
      "@type": "WebSite",
      "@id": "{{ site.url }}/#website",
      "name": "Ezconv",
      "url": "{{ site.url }}/",
      "description": "{{ seo.description | jsonString | safe }}",
      "inLanguage": "en",
      "publisher": {
        "@id": "{{ site.url }}/#organization"
      }
    },
    {%- endif %}
    {
      "@type": "WebPage",
      "@id": "{{ canonicalUrl }}#webpage",
      "url": "{{ canonicalUrl }}",
      "name": "{{ pageData.hero.title | jsonString | safe }}",
      "isPartOf": {
        "@id": "{{ site.url }}/#website"
      },
      "about": {
        "@type": "SoftwareApplication",
        "@id": "{{ canonicalUrl }}#application"
      },
      "inLanguage": "{{ langCode or 'en' }}"
    },
    {
      "@type": "SoftwareApplication",
      "@id": "{{ canonicalUrl }}#application",
      "name": "{{ pageData.hero.title | jsonString | safe }}",
      "url": "{{ canonicalUrl }}",
      "description": "{{ seo.schemaDescription | jsonString | safe }}",
      "applicationCategory": "MultimediaApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "inLanguage": "{{ langCode or 'en' }}",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    }
    {%- if hasFaqs %},
    {
      "@type": "FAQPage",
      "@id": "{{ canonicalUrl }}#faq",
      "isPartOf": {
        "@id": "{{ canonicalUrl }}#webpage"
      },
      "mainEntity": [
        {%- for item in pageData.faqs.items %}
        {
          "@type": "Question",
          "name": "{{ item.question | jsonString | safe }}",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "{{ item.answer | jsonString | safe }}"
          }
        }{%- if not loop.last %},{% endif %}
        {%- endfor %}
      ]
    }
    {%- endif %}
    {%- if hasHowTo %},
    {
      "@type": "HowTo",
      "@id": "{{ canonicalUrl }}#howto",
      "isPartOf": {
        "@id": "{{ canonicalUrl }}#webpage"
      },
      "name": "{{ pageData.overview.howTo.title | jsonString | safe }}",
      "step": [
        {%- for step in pageData.overview.howTo.steps %}
        {
          "@type": "HowToStep",
          "position": {{ loop.index }},
          "name": "{{ step.title | jsonString | safe }}",
          "text": "{{ step.description | jsonString | safe }}"
        }{%- if not loop.last %},{% endif %}
        {%- endfor %}
      ]
    }
    {%- endif %}
  ]
}
{%- else %}
{#- === TOOL PAGES === -#}
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "{{ canonicalUrl }}#webpage",
      "url": "{{ canonicalUrl }}",
      "name": "{{ pageData.hero.title | jsonString | safe }}",
      "isPartOf": {
        "@id": "{{ site.url }}/#website"
      },
      "about": {
        "@type": "SoftwareApplication",
        "@id": "{{ canonicalUrl }}#application"
      },
      "inLanguage": "{{ langCode or 'en' }}"
    },
    {
      "@type": "SoftwareApplication",
      "@id": "{{ canonicalUrl }}#application",
      "name": "{{ pageData.hero.title | jsonString | safe }}",
      "url": "{{ canonicalUrl }}",
      "description": "{{ seo.schemaDescription | jsonString | safe }}",
      "applicationCategory": "MultimediaApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "inLanguage": "{{ langCode or 'en' }}",
      "publisher": {
        "@id": "{{ site.url }}/#organization"
      },
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    }
    {%- if hasFaqs %},
    {
      "@type": "FAQPage",
      "@id": "{{ canonicalUrl }}#faq",
      "isPartOf": {
        "@id": "{{ canonicalUrl }}#webpage"
      },
      "mainEntity": [
        {%- for item in pageData.faqs.items %}
        {
          "@type": "Question",
          "name": "{{ item.question | jsonString | safe }}",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "{{ item.answer | jsonString | safe }}"
          }
        }{%- if not loop.last %},{% endif %}
        {%- endfor %}
      ]
    }
    {%- endif %}
    {%- if hasHowTo %},
    {
      "@type": "HowTo",
      "@id": "{{ canonicalUrl }}#howto",
      "isPartOf": {
        "@id": "{{ canonicalUrl }}#webpage"
      },
      "name": "{{ pageData.overview.howTo.title | jsonString | safe }}",
      "step": [
        {%- for step in pageData.overview.howTo.steps %}
        {
          "@type": "HowToStep",
          "position": {{ loop.index }},
          "name": "{{ step.title | jsonString | safe }}",
          "text": "{{ step.description | jsonString | safe }}"
        }{%- if not loop.last %},{% endif %}
        {%- endfor %}
      ]
    }
    {%- endif %}
  ]
}
{%- endif %}
</script>
