    <script>
        (function () {
            var toggleBtn = document.getElementById('advanced-settings-toggle');
            var panel = document.getElementById('advanced-settings-panel');
            var form = document.getElementById('multi-download-form');
            var convertBtn = document.getElementById('addUrlsBtn');
            if (!toggleBtn || !panel || !form || !convertBtn) return;

            var originalParent = convertBtn.parentElement;
            var originalNextSibling = convertBtn.nextSibling;
            var originalHtml = convertBtn.innerHTML;

            function isMobileViewport() {
                return window.matchMedia('(max-width: 768px)').matches;
            }

            function syncConvertButtonForViewport() {
                if (!originalParent) return;

                var isMobile = isMobileViewport();
                var isExpanded = toggleBtn.getAttribute('aria-expanded') === 'true';
                form.classList.toggle('advanced-expanded-mobile', isMobile && isExpanded);

                if (isMobile) {
                    convertBtn.classList.add('is-text', 'convert-below-advanced');
                    convertBtn.textContent = convertBtn.getAttribute('aria-label') || 'Convert';
                    var formParent = form.parentElement;
                    var errorMessage = document.getElementById('error-message');
                    if (formParent) {
                        if (errorMessage && errorMessage.parentElement === formParent) {
                            formParent.insertBefore(convertBtn, errorMessage);
                        } else {
                            formParent.insertBefore(convertBtn, panel);
                        }
                    }
                    return;
                }

                convertBtn.classList.remove('is-text', 'convert-below-advanced');
                convertBtn.innerHTML = originalHtml;

                if (convertBtn.parentElement !== originalParent) {
                    if (originalNextSibling && originalNextSibling.parentNode === originalParent) {
                        originalParent.insertBefore(convertBtn, originalNextSibling);
                    } else {
                        originalParent.appendChild(convertBtn);
                    }
                }
            }

            var observer = new MutationObserver(function () {
                if (isMobileViewport() && convertBtn.classList.contains('is-text')) {
                    convertBtn.textContent = convertBtn.getAttribute('aria-label') || 'Convert';
                }
            });
            observer.observe(convertBtn, { attributes: true, attributeFilter: ['aria-label'] });

            toggleBtn.addEventListener('click', function () {
                requestAnimationFrame(syncConvertButtonForViewport);
            });

            window.addEventListener('resize', syncConvertButtonForViewport);
            window.addEventListener('DOMContentLoaded', syncConvertButtonForViewport);
            syncConvertButtonForViewport();
        })();
    </script>
