<!-- Multi Download Form -->
<div id="multi-download-form" class="multiple-download-card">
    <!-- URL Input Area -->
    <div class="urls-input-container">
        <textarea id="urlsInput" class="urls-textarea" placeholder="https://youtube.com/watch?v=VID_1
https://youtube.com/watch?v=VID_2" rows="5"></textarea>
        <div id="keyword-suggestion-container" class="suggestion-container"></div>
    </div>

    <!-- Global Settings Row -->
    <div id="multi-download-form-actions">
        <div class="multi-format-selector-wrapper">
            <div class="multi-format-selector">
                <button type="button" id="advanced-settings-toggle" class="advanced-settings-toggle"
                    aria-label="Advanced Settings" aria-expanded="false"
                    aria-controls="advanced-settings-panel">
                    <div class="adv-settings-icon-wrap" aria-hidden="true">
                        <svg class="adv-settings-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="flex-shrink: 0;"><path d="M10 3C10.2761 3 10.5 3.22386 10.5 3.5V9.5H16.5L16.6006 9.50977C16.8286 9.55629 17 9.75829 17 10C17 10.2417 16.8286 10.4437 16.6006 10.4902L16.5 10.5H10.5V16.5C10.5 16.7761 10.2761 17 10 17C9.72386 17 9.5 16.7761 9.5 16.5V10.5H3.5C3.22386 10.5 3 10.2761 3 10C3 9.72386 3.22386 9.5 3.5 9.5H9.5V3.5C9.5 3.22386 9.72386 3 10 3Z"></path></svg>
                    </div>
                </button>
                <div class="multi-format-actions">
                    <div class="multi-format-dropdown-wrapper">
                        <select id="multi-format-select" class="multi-format-select" aria-label="Format">
                            <option value="mp4" selected>MP4</option>
                            <option value="mp3">MP3</option>
                        </select>
                        <div class="multi-select-arrow">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2">
                                <path d="M6 9l6 6 6-6" />
                            </svg>
                        </div>
                    </div>
                    <div class="multi-quality-dropdown-wrapper">
                        <select id="multi-quality-select-mp3"
                            class="multi-quality-select multi-quality-select--mp3"
                            aria-label="Audio quality" data-quality-select style="display: none;">
                            <option value="mp3-128" selected>MP3 - 128kbps</option>
                            <option value="mp3-320">MP3 - 320kbps</option>
                            <option value="flac">FLAC - Lossless</option>
                            <option value="ogg">OGG</option>
                            <option value="wav">WAV - Lossless</option>
                            <option value="opus">Opus</option>
                            <option value="m4a">M4A</option>
                        </select>
                        <select id="multi-quality-select-mp4"
                            class="multi-quality-select multi-quality-select--mp4"
                            aria-label="Video quality" data-quality-select>
                            <option value="mp4-2160">MP4 - 4K</option>
                            <option value="mp4-1440">MP4 - 2K</option>
                            <option value="mp4-1080">MP4 - 1080p</option>
                            <option value="mp4-720" selected>MP4 - 720p</option>
                            <option value="mp4-480">MP4 - 480p</option>
                            <option value="mp4-360">MP4 - 360p</option>
                            <option value="mp4-144">MP4 - 144p</option>
                            <option value="webm">WEBM</option>
                            <option value="mkv">MKV</option>
                        </select>
                        <div class="multi-select-arrow">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2">
                                <path d="M6 9l6 6 6-6" />
                            </svg>
                        </div>
                    </div>
                    <script>(function () { try { var p = JSON.parse(localStorage.getItem('Ezconv_format_preferences')); if (!p) return; var f = p.selectedFormat; if (f === 'mp3' || f === 'mp4') { var btns = document.querySelectorAll('.multi-format-btn'); btns.forEach(function (b) { b.classList.toggle('active', b.getAttribute('data-format') === f) }) } var s = f === 'mp4' ? document.getElementById('multi-quality-select-mp4') : document.getElementById('multi-quality-select-mp3'); if (!s) return; var v; if (f === 'mp4') { var vq = p.videoQuality || '720p'; v = (vq === 'webm' || vq === 'mkv') ? vq : 'mp4-' + vq.replace('p', '') } else { var af = p.audioFormat || 'mp3'; v = (af === 'mp3') ? 'mp3-' + (p.audioBitrate || '128') : af } s.value = v } catch (e) { } })()</script>
                    <button type="button" id="addUrlsBtn" class="multi-btn-convert" aria-label="Convert">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 256 256"><path d="M208.49,120.49a12,12,0,0,1-17,0L140,69V216a12,12,0,0,1-24,0V69L64.49,120.49a12,12,0,0,1-17-17l72-72a12,12,0,0,1,17,0l72,72A12,12,0,0,1,208.49,120.49Z"></path></svg>
                    </button>
                </div>
            </div>
        </div>
    </div>

   
   
</div>
 <!-- Advanced Settings Panel -->
    <div id="advanced-settings-panel" class="advanced-settings-panel" hidden>
        <div class="adv-settings-row">

            <!-- 1. Audio Track -->
            <div class="adv-setting-item adv-setting-item--audio">
                <span class="adv-setting-label">1. Audio Track</span>
                <div class="custom-dropdown" id="multi-audio-track-dropdown">
                    <div class="dropdown-trigger" tabindex="0" role="button" aria-haspopup="listbox"
                        aria-expanded="false">
                        <div class="selected-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="14"
                                viewBox="0 0 44 24" fill="none" stroke="currentColor" stroke-width="2"
                                stroke-linecap="round" stroke-linejoin="round"
                                class="icon-audio-language-horizontal" aria-hidden="true">
                                <g fill="currentColor" stroke="none" transform="translate(-2 0)">
                                    <path
                                        d="M19.4 .2C19.29 .27 19.20 .37 19.13 .49C19.07 .60 19.02 .72 19.01 .85C18.99 .98 18.99 1.12 19.03 1.24C19.06 1.37 19.12 1.49 19.2 1.6L20.8 .4C20.64 .18 20.40 .04 20.14 .01C19.87 -0.02 19.61 .04 19.4 .2ZM20.8 .4L20 1L19.2 1.59C20.37 3.16 21.00 5.06 21.00 7.01C20.99 8.97 20.35 10.87 19.17 12.42C19.01 12.64 18.94 12.90 18.98 13.16C19.02 13.43 19.16 13.66 19.37 13.83C19.58 13.99 19.84 14.05 20.11 14.02C20.37 13.98 20.61 13.84 20.77 13.63C22.21 11.73 22.99 9.41 23 7.02C23.00 4.63 22.23 2.31 20.8 .4ZM10 2C8.67 2 7.40 2.52 6.46 3.46C5.52 4.40 5 5.67 5 7C5 8.32 5.52 9.59 6.46 10.53C7.40 11.47 8.67 12 10 12C11.32 12 12.59 11.47 13.53 10.53C14.47 9.59 15 8.32 15 7C15 5.67 14.47 4.40 13.53 3.46C12.59 2.52 11.32 2 10 2ZM16.17 2.29C15.97 2.48 15.86 2.73 15.86 2.99C15.85 3.26 15.95 3.51 16.14 3.71C16.98 4.58 17.44 5.68 17.49 6.80L17.5 7.02C17.49 8.22 17.01 9.40 16.10 10.32C15.92 10.51 15.83 10.77 15.83 11.03C15.84 11.29 15.95 11.53 16.13 11.71C16.32 11.90 16.57 12.00 16.83 12.00C17.09 12.00 17.34 11.90 17.53 11.72C18.78 10.44 19.49 8.77 19.5 7.03L19.49 6.71C19.42 5.09 18.74 3.53 17.58 2.32C17.49 2.23 17.38 2.15 17.26 2.10C17.14 2.05 17.01 2.02 16.88 2.01C16.75 2.01 16.62 2.03 16.49 2.08C16.37 2.13 16.26 2.20 16.17 2.29ZM10.39 13.01L10 13C8.01 12.99 6.10 13.73 4.63 15.06L4.34 15.34C3.60 16.08 3.01 16.96 2.60 17.93C2.20 18.90 1.99 19.94 2 21C2 21.26 2.10 21.51 2.29 21.70C2.48 21.89 2.73 22 3 22C3.26 22 3.51 21.89 3.70 21.70C3.89 21.51 4 21.26 4 21C4.00 19.40 4.63 17.88 5.75 16.75L5.97 16.55C7.07 15.55 8.51 15 10 15L10.29 15.00C11.78 15.08 13.18 15.70 14.24 16.75L14.44 16.97C15.44 18.07 16 19.51 16 21C16 21.26 16.10 21.51 16.29 21.70C16.48 21.89 16.73 22 17 22C17.26 22 17.51 21.89 17.70 21.70C17.89 21.51 18 21.26 18 21C18.00 19.01 17.26 17.10 15.93 15.63L15.65 15.34C14.25 13.93 12.37 13.10 10.39 13.01Z">
                                    </path>
                                </g>
                                <g transform="translate(23.8 1.6) scale(0.75)">
                                    <path d="m5 8 6 6"></path>
                                    <path d="m4 14 6-6 2-3"></path>
                                    <path d="M2 5h12"></path>
                                    <path d="M7 2h1"></path>
                                    <path d="m22 22-5-10-5 10"></path>
                                    <path d="M14 18h6"></path>
                                </g>
                            </svg>
                        </div>
                        <div class="selected-content">
                            <span class="selected-text">Original</span>
                        </div>
                        <svg class="dropdown-arrow" width="16" height="16" viewBox="0 0 24 24"
                            fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path d="M6 9l6 6 6-6" />
                        </svg>
                    </div>
                    <div class="dropdown-menu hidden">
                        <div class="dropdown-search">
                            <input type="text" placeholder="Search..." aria-label="Search language">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2" class="search-icon"
                                aria-hidden="true">
                                <circle cx="11" cy="11" r="8"></circle>
                                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                            </svg>
                        </div>
                        <div class="dropdown-options" role="listbox"></div>
                    </div>
                    <input type="hidden" id="multi-audio-track-value" value="original" name="audioTrack">
                </div>
            </div>

            <!-- 2. Filename Style -->
            <div class="adv-setting-item adv-setting-item--filename-style">
                <span class="adv-setting-label">2. Filename Style</span>
                <div class="filename-style-tabs" id="filename-style-tabs">
                    <button type="button" class="fs-tab" data-style="classic">classic</button>
                    <button type="button" class="fs-tab active" data-style="basic">basic</button>
                    <button type="button" class="fs-tab" data-style="pretty">pretty</button>
                    <button type="button" class="fs-tab" data-style="nerdy">nerdy</button>
                </div>
                <!-- Filename Preview -->
                <div class="filename-preview" id="filename-preview">
                    <div class="fp-row" id="fp-video-row">
                        <svg class="fp-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"></rect>
                            <line x1="7" y1="2" x2="7" y2="22"></line>
                            <line x1="17" y1="2" x2="17" y2="22"></line>
                            <line x1="2" y1="12" x2="22" y2="12"></line>
                            <line x1="2" y1="7" x2="7" y2="7"></line>
                            <line x1="2" y1="17" x2="7" y2="17"></line>
                            <line x1="17" y1="7" x2="22" y2="7"></line>
                            <line x1="17" y1="17" x2="22" y2="17"></line>
                        </svg>
                        <div class="fp-text">
                            <span class="fp-name" id="fp-video-name">Video Title - Author (1080p).mp4</span>
                            <span class="fp-sub">video file preview</span>
                        </div>
                    </div>
                    <div class="fp-row" id="fp-audio-row" style="display: none;">
                        <svg class="fp-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9 18V5l12-2v13"></path>
                            <circle cx="6" cy="18" r="3"></circle>
                            <circle cx="18" cy="16" r="3"></circle>
                        </svg>
                        <div class="fp-text">
                            <span class="fp-name" id="fp-audio-name">Video Title - Author (192k).mp3</span>
                            <span class="fp-sub">audio file preview</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <div class="adv-settings-row">

            <!-- 3. Playlist Mode -->
            <div class="adv-setting-item">
                <span class="adv-setting-label">3. Playlist Mode</span>
                <button type="button" class="mode-switch" id="playlist-mode-toggle" role="switch"
                    aria-checked="false" aria-label="Playlist Mode">
                    <span class="mode-switch-thumb"></span>
                </button>
            </div>

            <!-- 4. Channel Mode -->
            <div class="adv-setting-item">
                <span class="adv-setting-label">4. Channel Mode</span>
                <button type="button" class="mode-switch" id="channel-mode-toggle" role="switch"
                    aria-checked="false" aria-label="Channel Mode">
                    <span class="mode-switch-thumb"></span>
                </button>
            </div>

            <!-- 5. Cut Video -->
            <div class="adv-setting-item">
                <span class="adv-setting-label">5. Cut Video</span>
                <button type="button" class="mode-switch" id="trim-mode-toggle" role="switch"
                    aria-checked="false" aria-label="Trim/Cut Mode">
                    <span class="mode-switch-thumb"></span>
                </button>
            </div>

            <!-- 6. Metadata -->
            <div class="adv-setting-item">
                <span class="adv-setting-label">6. Metadata</span>
                <button type="button" class="mode-switch" id="metadata-mode-toggle" role="switch"
                    aria-checked="false" aria-label="Metadata">
                    <span class="mode-switch-thumb"></span>
                </button>
            </div>

        </div>

        <!-- Cutting Interface (shown when Trim/Cut = ON) -->
        <div id="cutting-interface" class="cutting-interface" hidden>
            <div id="stream-editor" class="stream-editor">
                <div class="stream-player-wrap">
                    <div id="stream-player" class="stream-player"></div>
                </div>
                <div class="stream-settings">
                    <div class="stream-step">
                        <span class="stream-step-label">Cut range (Start – End):</span>
                        <div id="trim-slider" class="trim-slider"></div>
                        <div class="stream-time-row">
                            <div class="stream-time-field">
                                <span class="stream-time-label">Start</span>
                                <input type="text" id="trim-start" class="time-input" value="0:00"
                                    autocomplete="off" />
                            </div>
                            <div class="stream-time-field">
                                <span class="stream-time-label">End</span>
                                <input type="text" id="trim-end" class="time-input" value="0:00"
                                    autocomplete="off" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
 <div id="error-message" class="error-message" role="alert" aria-live="polite"></div>
    <div id="success-message" class="success-message" role="status" aria-live="polite"></div>

<!-- Keyword Search Results (outside form card) -->
<section id="keyword-search-results-section" class="keyword-search-results-section"
    aria-live="polite" style="display: none;">
    <div id="keyword-search-results-container"></div>
</section>
