---
layout: base.njk
pagination:
  data: indexPages
  size: 1
  alias: pageInfo
eleventyComputed:
  permalink: "{{ pageInfo.permalink }}"
  lang: "{{ pageInfo.lang }}"
  pageKey: "{{ pageInfo.pageKey }}"
---
{%- set base = i18nBase[lang] or i18nBase['en'] -%}
{%- set page = i18nPages[pageKey][lang] or i18nPages[pageKey].en -%}

<!-- HERO SECTION -->
<section class="hero-section">
    <div class="hero-container">

        <!-- Main Card -->
        <div class="hero-card">

            <!-- Search View -->
            <div id="search-view" class="fade-in">

                <!-- REQUIRED: Main Download Form -->
                <form id="downloadForm" class="converter-form" autocomplete="off">
                    <!-- Invisible submit for Enter key -->

                    <div class="input-group">
                        <div class="input-wrapper" id="input-wrapper">
                            <!-- REQUIRED: #videoUrl input -->
                            <input
                                type="text"
                                id="videoUrl"
                                class="video-input"
                                placeholder="{{ base.hero.placeholder }}"
                                autocomplete="off"
                                autocapitalize="off"
                                autocorrect="off"
                                spellcheck="false"
                            />
                            <div class="input-actions">
                                <!-- REQUIRED: #input-action-button -->
                                <button
                                    type="button"
                                    id="input-action-button"
                                    class="btn-paste"
                                    data-action="paste"
                                >
                                    <!-- Paste Icon -->
                                    <svg class="paste-icon" width="14" height="14" viewBox="0 0 640 640" fill="currentColor">
                                        <path d="M128 64C92.7 64 64 92.7 64 128L64 448C64 483.3 92.7 512 128 512L240 512L240 288C240 226.1 290.1 176 352 176L416 176L416 128C416 92.7 387.3 64 352 64L128 64zM312 176L168 176C154.7 176 144 165.3 144 152C144 138.7 154.7 128 168 128L312 128C325.3 128 336 138.7 336 152C336 165.3 325.3 176 312 176zM352 224C316.7 224 288 252.7 288 288L288 512C288 547.3 316.7 576 352 576L512 576C547.3 576 576 547.3 576 512L576 346.5C576 329.5 569.3 313.2 557.3 301.2L498.8 242.7C486.8 230.7 470.5 224 453.5 224L352 224z"/>
                                    </svg>
                                    <span class="btn-state--paste">{{ base.hero.pasteButton }}</span>

                                    <!-- Clear Icon (hidden by default) -->
                                    <svg class="clear-icon hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                                        <line x1="18" y1="6" x2="6" y2="18"></line>
                                        <line x1="6" y1="6" x2="18" y2="18"></line>
                                    </svg>
                                    <span class="btn-state--clear hidden">{{ base.hero.clearButton }}</span>
                                </button>
                            </div>
                        </div>

                        <!-- REQUIRED: #suggestion-container with class "suggesstion-list" (typo is intentional) -->
                        <div id="suggestion-container" class="suggestion-container suggesstion-list"></div>
                    </div>

                    <!-- REQUIRED: #format-selector-container INSIDE form -->
                    <div id="format-selector-container">
                        <div class="format-selector-wrapper">
                            <div class="format-selector">
                                <!-- Format Select -->
                                <div class="quality-wrapper format-wrapper">
                                    <select id="format-select" class="quality-select format-select" data-format-select>
                                        <option value="mp3">MP3</option>
                                        <option value="mp4">MP4</option>
                                    </select>
                                    <script>(function(){try{var p=JSON.parse(localStorage.getItem('mp3fast_format_preferences'));if(!p)return;var s=document.getElementById('format-select');if(s&&(p.selectedFormat==='mp3'||p.selectedFormat==='mp4'))s.value=p.selectedFormat}catch(e){}})()</script>
                                    <div class="select-arrow">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                                    </div>
                                </div>

                                <!-- Quality Dropdown -->
                                <div class="quality-wrapper">
                                    <div class="quality-dropdown-wrapper">
                                        <select id="quality-select-mp3" class="quality-select quality-select--mp3" aria-label="Select audio quality" data-quality-select>
                                            <option value="mp3-320">MP3 - 320kbps</option>
                                            <option value="mp3-192">MP3 - 192kbps</option>
                                            <option value="mp3-128" selected>MP3 - 128kbps</option>
                                            <option value="mp3-64">MP3 - 64kbps</option>
                                            <option value="flac">FLAC - Lossless</option>
                                            <option value="wav">WAV - Lossless</option>
                                            <option value="m4a">M4A</option>
                                            <option value="opus">Opus</option>
                                            <option value="ogg">OGG</option>
                                        </select>
                                        <select id="quality-select-mp4" class="quality-select quality-select--mp4" aria-label="Select video quality" data-quality-select>
                                            <option value="mp4-2160">MP4 - 4K</option>
                                            <option value="mp4-1440">MP4 - 2K</option>
                                            <option value="mp4-1080">MP4 - 1080p</option>
                                            <option value="mp4-720" selected>MP4 - 720p</option>
                                            <option value="mp4-480">MP4 - 480p</option>
                                            <option value="mp4-360">MP4 - 360p</option>
                                            <option value="mp4-144">MP4 - 144p</option>
                                            <option value="webm">WEBM</option>
                                            <option value="mkv">MKV</option>
                                        </select>
                                        <div class="select-arrow">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                                        </div>
                                    </div>
                                    <script>(function(){try{var p=JSON.parse(localStorage.getItem('mp3fast_format_preferences'));if(!p)return;var f=p.selectedFormat||'mp3';var s=f==='mp4'?document.getElementById('quality-select-mp4'):document.getElementById('quality-select-mp3');if(!s)return;var v;if(f==='mp4'){var vq=p.videoQuality||'720p';v=(vq==='webm'||vq==='mkv')?vq:'mp4-'+vq.replace('p','')}else{var af=p.audioFormat||'mp3';v=af==='mp3'?'mp3-'+(p.audioBitrate||'128'):af}s.value=v}catch(e){}})()</script>
                                </div>

                                <!-- Convert Button -->
                                <button type="submit" class="btn-convert">
                                    <span>{{ base.hero.convertButton }}</span>
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Error Message -->
                    <div id="error-message" class="error-message hidden"></div>
                </form>
            </div>
            <!-- End Search View -->

            <!-- Result View (Hidden by default) -->
            <div id="result-view" class="hidden fade-in">
                <!-- REQUIRED: #content-area - TypeScript will render preview here -->
                <div id="content-area"></div>
            </div>
            <!-- End Result View -->

        </div>

    </div>
</section>

<!-- REQUIRED: Search Results Section -->
<section id="search-results-section" style="display: none;">
    <div class="container">
        <!-- REQUIRED: #search-results-container -->
        <div id="search-results-container"></div>
    </div>
</section>

<!-- SEO / TEXT CONTENT -->
<section class="content-section">
    <div class="content-wrapper">
        <h1>{{ page.h1 }}</h1>
        <p>{{ page.intro }}</p>

        <h2>{{ page.primary_features.h2 }}</h2>
        <ul>
            {%- for item in page.primary_features.items %}
            <li>{{ item }}</li>
            {%- endfor %}
        </ul>

        <h2>{{ page.performance.h2 }}</h2>
        <p>{{ page.performance.content }}</p>

        <h2>{{ page.how_to.h2 }}</h2>
        <ol>
            {%- for step in page.how_to.steps %}
            <li>{{ step.content }}</li>
            {%- endfor %}
        </ol>

        <h2>{{ page.limitations.h2 }}</h2>
        <p>{{ page.limitations.content }}</p>

        <p>{{ page.privacy_notice.content }}</p>

        <p>{{ page.responsibility_notice.content }}</p>
    </div>
</section>
