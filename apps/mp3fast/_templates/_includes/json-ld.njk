{#- JSON-LD Structured Data for SEO -#}
{%- set isHomePage = (pageKey == 'index') -%}
{%- set isRootHomePage = isHomePage and (lang == 'en' or not lang) -%}
{%- set hasInstructions = pageData.instructions and pageData.instructions.steps -%}
{%- set hasFaqs = pageData.faqs and pageData.faqs.items -%}

{#- Build canonical URL -#}
{%- set cleanUrl = page.url | replace('/index.html', '/') | replace('.html', '') -%}
{%- set canonicalUrl = site.url + cleanUrl -%}

<script type="application/ld+json">
{%- if isHomePage %}
{#- === HOMEPAGE === -#}
{
  "@context": "https://schema.org",
  "@graph": [
    {%- if isRootHomePage %}
    {
      "@type": "Organization",
      "@id": "{{ site.url }}/#organization",
      "name": "MP3Fast",
      "url": "{{ site.url }}",
      "logo": {
        "@type": "ImageObject",
        "url": "{{ site.url }}/favicon-512x512.png"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer support",
        "email": "contact.mp3fast@gmail.com"
      }
    },
    {
      "@type": "WebSite",
      "@id": "{{ site.url }}/#website",
      "name": "MP3Fast",
      "url": "{{ site.url }}",
      "description": "{{ seo.description | jsonString | safe }}",
      "inLanguage": "en",
      "publisher": {
        "@id": "{{ site.url }}/#organization"
      }
    },
    {%- endif %}
    {
      "@type": "WebPage",
      "@id": "{{ canonicalUrl }}#webpage",
      "url": "{{ canonicalUrl }}",
      "name": "MP3Fast - Free YouTube to MP3 Converter",
      "isPartOf": {
        "@id": "{{ site.url }}/#website"
      },
      "about": {
        "@type": "SoftwareApplication",
        "@id": "{{ canonicalUrl }}#application"
      },
      "inLanguage": "{{ lang or 'en' }}"
    },
    {
      "@type": "SoftwareApplication",
      "@id": "{{ canonicalUrl }}#application",
      "name": "MP3Fast - YouTube to MP3 Converter",
      "url": "{{ canonicalUrl }}",
      "description": "{{ seo.description | jsonString | safe }}",
      "applicationCategory": "MultimediaApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "inLanguage": "{{ lang or 'en' }}",
      "publisher": {
        "@id": "{{ site.url }}/#organization"
      },
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    }
    {%- if hasFaqs %},
    {
      "@type": "FAQPage",
      "@id": "{{ canonicalUrl }}#faq",
      "isPartOf": {
        "@id": "{{ canonicalUrl }}#webpage"
      },
      "mainEntity": [
        {%- for item in pageData.faqs.items %}
        {
          "@type": "Question",
          "name": "{{ item.question | jsonString | safe }}",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "{{ item.answer | jsonString | safe }}"
          }
        }{%- if not loop.last %},{% endif %}
        {%- endfor %}
      ]
    }
    {%- endif %}
    {%- if hasInstructions %},
    {
      "@type": "HowTo",
      "@id": "{{ canonicalUrl }}#howto",
      "isPartOf": {
        "@id": "{{ canonicalUrl }}#webpage"
      },
      "name": "{{ pageData.instructions.title | jsonString | safe }}",
      "step": [
        {%- for step in pageData.instructions.steps %}
        {
          "@type": "HowToStep",
          "position": {{ loop.index }},
          "text": "{{ step | jsonString | safe }}"
        }{%- if not loop.last %},{% endif %}
        {%- endfor %}
      ]
    }
    {%- endif %}
  ]
}
{%- else %}
{#- === OTHER PAGES === -#}
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "{{ canonicalUrl }}#webpage",
      "url": "{{ canonicalUrl }}",
      "name": "{{ seo.title | jsonString | safe }}",
      "isPartOf": {
        "@id": "{{ site.url }}/#website"
      },
      "about": {
        "@type": "SoftwareApplication",
        "@id": "{{ canonicalUrl }}#application"
      },
      "inLanguage": "{{ lang or 'en' }}"
    },
    {
      "@type": "SoftwareApplication",
      "@id": "{{ canonicalUrl }}#application",
      "name": "{{ seo.title | jsonString | safe }}",
      "url": "{{ canonicalUrl }}",
      "description": "{{ seo.description | jsonString | safe }}",
      "applicationCategory": "MultimediaApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "inLanguage": "{{ lang or 'en' }}",
      "publisher": {
        "@id": "{{ site.url }}/#organization"
      },
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    }
    {%- if hasFaqs %},
    {
      "@type": "FAQPage",
      "@id": "{{ canonicalUrl }}#faq",
      "isPartOf": {
        "@id": "{{ canonicalUrl }}#webpage"
      },
      "mainEntity": [
        {%- for item in pageData.faqs.items %}
        {
          "@type": "Question",
          "name": "{{ item.question | jsonString | safe }}",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "{{ item.answer | jsonString | safe }}"
          }
        }{%- if not loop.last %},{% endif %}
        {%- endfor %}
      ]
    }
    {%- endif %}
    {%- if hasInstructions %},
    {
      "@type": "HowTo",
      "@id": "{{ canonicalUrl }}#howto",
      "isPartOf": {
        "@id": "{{ canonicalUrl }}#webpage"
      },
      "name": "{{ pageData.instructions.title | jsonString | safe }}",
      "step": [
        {%- for step in pageData.instructions.steps %}
        {
          "@type": "HowToStep",
          "position": {{ loop.index }},
          "text": "{{ step | jsonString | safe }}"
        }{%- if not loop.last %},{% endif %}
        {%- endfor %}
      ]
    }
    {%- endif %}
  ]
}
{%- endif %}
</script>
