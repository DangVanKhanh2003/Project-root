{%- set base = i18nBase[lang] or i18nBase['en'] -%}
{%- set pageData = i18nPages[pageKey or 'index'][lang or 'en'] -%}
{%- set seo = pageData.seo -%}
{#- Language-specific configs for multilingual SEO -#}
{%- set localeMap = {
  en: 'en_US',
  ar: 'ar_SA',
  bn: 'bn_BD',
  de: 'de_DE',
  es: 'es_ES',
  fr: 'fr_FR',
  hi: 'hi_IN',
  id: 'id_ID',
  it: 'it_IT',
  ja: 'ja_JP',
  ko: 'ko_KR',
  ms: 'ms_MY',
  my: 'my_MM',
  pt: 'pt_BR',
  ru: 'ru_RU',
  th: 'th_TH',
  tr: 'tr_TR',
  ur: 'ur_PK',
  vi: 'vi_VN'
} -%}
{%- set locale = localeMap[lang] or 'en_US' -%}
{%- set rtlLanguages = ['ar', 'ur'] -%}
<!DOCTYPE html>
<html lang="{{ lang or 'en' }}"{% if lang in rtlLanguages %} dir="rtl"{% endif %}>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="index, follow">

    <!-- SEO Metadata -->
    <title>{{ seo.title }}</title>
    <meta name="description" content="{{ seo.description | safe }}" />
    {%- set cleanUrl = page.url | replace('/index.html', '/') | replace('.html', '') %}
    <link rel="canonical" href="{{ site.url }}{{ cleanUrl }}">

    <!-- hreflang tags for multilingual SEO -->
    {%- for langItem in site.languages %}
    {%- if langItem.isDefault %}
    <link rel="alternate" hreflang="{{ langItem.code }}" href="{{ site.url }}/" />
    {%- else %}
    <link rel="alternate" hreflang="{{ langItem.code }}" href="{{ site.url }}/{{ langItem.code }}/" />
    {%- endif %}
    {%- endfor %}
    <link rel="alternate" hreflang="x-default" href="{{ site.url }}/" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="MP3Fast">
    <meta property="og:locale" content="{{ locale }}">
    <meta property="og:title" content="{{ seo.ogTitle or seo.title }}">
    <meta property="og:description" content="{{ seo.ogDescription or seo.description }}">
    <meta property="og:image" content="{{ site.url }}/logo.png">
    <meta property="og:url" content="{{ site.url }}{{ cleanUrl }}">

    <!-- Fonts -->
    <link rel="preload" href="/assest/fonts/fredoka/Fredoka-Bold.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="stylesheet" href="/assest/fonts/fonts.css">

    <!-- Favicons -->
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/favicon.png" type="image/png">
    <link type="image/png" sizes="16x16" rel="icon" href="/favicon1616.png">
    <link type="image/png" sizes="32x32" rel="icon" href="/favicon3232.png">
    <link type="image/png" sizes="48x48" rel="icon" href="/favicon4848.png">
    <link type="image/png" sizes="96x96" rel="icon" href="/favicon9696.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">

    <!-- TypeScript Module -->
    <script type="module" src="/src/main.ts"></script>

    <!-- JSON-LD Structured Data -->
    {% include "json-ld.njk" %}
</head>
<body>

{%- set homeUrl = '/' if (lang == 'en' or not lang) else '/' + lang + '/' -%}
    <!-- HEADER -->
    <div class="header-wrapper">
        <div id="header" class="nav-links">
            <a href="{{ homeUrl }}" class="nav-link">{{ base.nav.home }}</a>
            <a href="/faq/" class="nav-link">{{ base.nav.faq }}</a>
            <div class="language-selector">
                <button type="button" class="lang-btn" aria-haspopup="true" aria-expanded="false">
                    {%- if lang == 'en' %}English{% elif lang == 'ar' %}العربية{% elif lang == 'bn' %}বাংলা{% elif lang == 'de' %}Deutsch{% elif lang == 'es' %}Español{% elif lang == 'fr' %}Français{% elif lang == 'hi' %}हिन्दी{% elif lang == 'id' %}Indonesia{% elif lang == 'it' %}Italiano{% elif lang == 'ja' %}日本語{% elif lang == 'ko' %}한국어{% elif lang == 'my' %}မြန်မာ{% elif lang == 'ms' %}Melayu{% elif lang == 'pt' %}Português{% elif lang == 'ru' %}Русский{% elif lang == 'th' %}ไทย{% elif lang == 'tr' %}Türkçe{% elif lang == 'ur' %}اردو{% elif lang == 'vi' %}Tiếng Việt{% else %}English{% endif -%}
                    <span class="arrow"></span>
                </button>
                <div class="dropdown-menu">
                    <ul class="lang-menu">
                        <li><a data-lang="en" href="/"{% if lang == 'en' %} class="active"{% endif %}>English</a></li>
                        <li><a data-lang="ar" href="/ar/"{% if lang == 'ar' %} class="active"{% endif %}>العربية</a></li>
                        <li><a data-lang="bn" href="/bn/"{% if lang == 'bn' %} class="active"{% endif %}>বাংলা</a></li>
                        <li><a data-lang="de" href="/de/"{% if lang == 'de' %} class="active"{% endif %}>Deutsch</a></li>
                        <li><a data-lang="es" href="/es/"{% if lang == 'es' %} class="active"{% endif %}>Español</a></li>
                        <li><a data-lang="fr" href="/fr/"{% if lang == 'fr' %} class="active"{% endif %}>Français</a></li>
                        <li><a data-lang="hi" href="/hi/"{% if lang == 'hi' %} class="active"{% endif %}>हिन्दी</a></li>
                        <li><a data-lang="id" href="/id/"{% if lang == 'id' %} class="active"{% endif %}>Indonesia</a></li>
                        <li><a data-lang="it" href="/it/"{% if lang == 'it' %} class="active"{% endif %}>Italiano</a></li>
                        <li><a data-lang="ja" href="/ja/"{% if lang == 'ja' %} class="active"{% endif %}>日本語</a></li>
                        <li><a data-lang="ko" href="/ko/"{% if lang == 'ko' %} class="active"{% endif %}>한국어</a></li>
                        <li><a data-lang="my" href="/my/"{% if lang == 'my' %} class="active"{% endif %}>မြန်မာ</a></li>
                        <li><a data-lang="ms" href="/ms/"{% if lang == 'ms' %} class="active"{% endif %}>Melayu</a></li>
                        <li><a data-lang="pt" href="/pt/"{% if lang == 'pt' %} class="active"{% endif %}>Português</a></li>
                        <li><a data-lang="ru" href="/ru/"{% if lang == 'ru' %} class="active"{% endif %}>Русский</a></li>
                        <li><a data-lang="th" href="/th/"{% if lang == 'th' %} class="active"{% endif %}>ไทย</a></li>
                        <li><a data-lang="tr" href="/tr/"{% if lang == 'tr' %} class="active"{% endif %}>Türkçe</a></li>
                        <li><a data-lang="ur" href="/ur/"{% if lang == 'ur' %} class="active"{% endif %}>اردو</a></li>
                        <li><a data-lang="vi" href="/vi/"{% if lang == 'vi' %} class="active"{% endif %}>Tiếng Việt</a></li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="logo-container">
            <a href="{{ homeUrl }}"><img src="/logo.png" alt="MP3Fast Logo" class="logo-img" /></a>
            <a href="{{ homeUrl }}" class="logo-text">MP3Fast</a>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <main>
        {{ content | safe }}
    </main>

    <!-- FOOTER -->
    <footer class="footer">
        <div class="footer-content">
            <p class="footer-text">{{ base.footer.copyright }}</p>
            <div class="footer-links">
                <a href="/contact/" class="footer-link">{{ base.footer.contact }}</a>
                <a href="/copyright-claims/" class="footer-link">{{ base.footer.copyrightClaims }}</a>
                <a href="/privacy-policy/" class="footer-link">{{ base.footer.privacyPolicy }}</a>
                <a href="/terms-of-use/" class="footer-link">{{ base.footer.terms }}</a>
            </div>
        </div>
    </footer>

    <!-- Language Selector Toggle -->
    <script>
        (function() {
            const selector = document.querySelector('.language-selector');
            const btn = selector?.querySelector('.lang-btn');
            if (!selector || !btn) return;

            // Detect current language from URL
            const path = window.location.pathname;
            const langMatch = path.match(/^\/(ar|bn|de|es|fr|hi|id|it|ja|ko|my|ms|pt|ru|th|tr|ur|vi)\//);
            const currentLang = langMatch ? langMatch[1] : 'en';

            // Set active class and update button text
            const links = selector.querySelectorAll('.lang-menu a');
            links.forEach(link => {
                link.classList.remove('active');
                if (link.dataset.lang === currentLang) {
                    link.classList.add('active');
                    btn.firstChild.textContent = link.textContent;
                }
            });

            // Toggle dropdown
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                selector.classList.toggle('open');
                btn.setAttribute('aria-expanded', selector.classList.contains('open'));
            });

            // Close on outside click
            document.addEventListener('click', function(e) {
                if (!selector.contains(e.target)) {
                    selector.classList.remove('open');
                    btn.setAttribute('aria-expanded', 'false');
                }
            });
        })();
    </script>
</body>
</html>
