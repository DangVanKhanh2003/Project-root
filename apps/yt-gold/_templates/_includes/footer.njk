{%- set langPrefix = '' if (lang == 'en' or not lang) else '/' + lang -%}
{%- set homeUrl = '/' if (lang == 'en' or not lang) else '/' + lang + '/' -%}

<!-- FOOTER -->
<footer>
    <div class="footer-container">
        <a href="{{ homeUrl }}" class="footer-logo">ytmp3.my</a>
        <nav class="footer-nav">
            <a href="{{ homeUrl }}" class="footer-link">{{ base.footer.ytToMp3 }}</a>
            <a href="{{ langPrefix }}/youtube-to-mp3-320kbps-converter" class="footer-link">{{ base.footer.ytToMp3320 }}</a>
            <a href="{{ langPrefix }}/youtube-to-wav-converter" class="footer-link">{{ base.footer.ytToWav }}</a>
            <a href="{{ langPrefix }}/youtube-to-flac-converter" class="footer-link">{{ base.footer.ytToFlac }}</a>
            <a href="{{ langPrefix }}/youtube-to-m4a-converter" class="footer-link">{{ base.footer.ytToM4a }}</a>
        </nav>
        <div class="footer-links">
            <a href="/contact" class="footer-link">{{ base.footer.contact }}</a>
            <a href="/faq" class="footer-link">{{ base.footer.faq }}</a>
            <a href="/privacy-policy" class="footer-link">{{ base.footer.privacyPolicy }}</a>
            <a href="/copyright-claims" class="footer-link">{{ base.footer.copyrightClaims }}</a>
            <a href="/terms-of-use" class="footer-link">{{ base.footer.terms }}</a>
        </div>
        <p class="footer-copyright">{{ base.footer.copyright }}</p>
    </div>
</footer>
