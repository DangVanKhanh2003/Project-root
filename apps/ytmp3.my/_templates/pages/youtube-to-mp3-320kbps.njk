---
layout: base.njk
pagination:
  data: mp3320Pages
  size: 1
  alias: pageInfo
eleventyComputed:
  permalink: "{{ pageInfo.permalink }}"
  lang: "{{ pageInfo.lang }}"
  pageKey: "{{ pageInfo.pageKey }}"
---
{%- set base = i18nBase[lang] or i18nBase['en'] -%}
{%- set page = i18nPages[pageKey][lang] or i18nPages[pageKey].en -%}
{%- set langPrefix = '' if (lang == 'en' or not lang) else '/' + lang -%}

<!-- HERO SECTION -->
<section class="hero-section">
    <div class="decorative-glow"></div>
    <div class="hero-container">
        <div class="hero-card">
            <div id="hero-header" class="hero-header">
                <h1>{{ page.hero.title }} <span class="title-accent" id="title-format">{{ page.hero.titleAccent }}</span></h1>
            </div>

            <div id="search-view" class="fade-in">
                <p class="hero-subtitle">{{ page.hero.subtitle | safe }}</p>

                <form id="downloadForm" class="form-container">
                    <div class="input-group">
                        <div class="input-wrapper" id="input-wrapper">
                            <input type="text" id="videoUrl" class="video-input"
                                placeholder="{{ base.hero.placeholder }}" autocomplete="off">
                            <div class="input-actions">
                                <button type="button" id="input-action-button" class="btn-paste" data-action="paste">
                                    <svg class="paste-icon" width="14" height="14" viewBox="0 0 24 24"
                                        fill="none" stroke="currentColor" stroke-width="2">
                                        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                                        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                                    </svg>
                                    <span class="btn-state--paste">{{ base.hero.pasteButton }}</span>
                                    <svg class="clear-icon hidden" width="18" height="18" viewBox="0 0 24 24"
                                        fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                                        <line x1="18" y1="6" x2="6" y2="18"></line>
                                        <line x1="6" y1="6" x2="18" y2="18"></line>
                                    </svg>
                                    <span class="btn-state--clear hidden">{{ base.hero.clearButton }}</span>
                                </button>
                            </div>
                        </div>
                        <div id="suggestion-container" class="suggestion-container"></div>
                    </div>

                    <div id="format-selector-container">
                        <div class="format-selector-wrapper">
                            <div class="format-selector">
                                <div class="format-toggle">
                                    <button type="button" class="format-btn active" data-format="mp3">MP3</button>
                                    <button type="button" class="format-btn" data-format="mp4">MP4</button>
                                </div>
                                <div class="quality-wrapper">
                                    <div class="quality-dropdown-wrapper">
                                        <select id="quality-select-mp3" class="quality-select quality-select--mp3"
                                            aria-label="Audio quality" data-quality-select>
                                            <option value="mp3-320" selected>MP3 - 320kbps</option>
                                            <option value="mp3-192">MP3 - 192kbps</option>
                                            <option value="mp3-128">MP3 - 128kbps</option>
                                            <option value="mp3-64">MP3 - 64kbps</option>
                                            <option value="flac">FLAC - Lossless</option>
                                            <option value="wav">WAV - Lossless</option>
                                            <option value="m4a">M4A</option>
                                            <option value="opus">Opus</option>
                                            <option value="ogg">OGG</option>
                                        </select>
                                        <select id="quality-select-mp4" class="quality-select quality-select--mp4"
                                            aria-label="Video quality" data-quality-select>
                                            <option value="mp4-1080">MP4 - 1080p</option>
                                            <option value="mp4-720" selected>MP4 - 720p</option>
                                            <option value="mp4-480">MP4 - 480p</option>
                                            <option value="mp4-360">MP4 - 360p</option>
                                            <option value="mp4-240">MP4 - 240p</option>
                                            <option value="mp4-144">MP4 - 144p</option>
                                            <option value="webm">WEBM</option>
                                            <option value="mkv">MKV</option>
                                        </select>
                                        <div class="select-arrow">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M6 9l6 6 6-6" />
                                            </svg>
                                        </div>
                                    </div>
                                    <div class="audio-dropdown-wrapper">
                                        <div class="custom-dropdown" id="audio-track-dropdown">
                                            <div class="dropdown-trigger" tabindex="0" role="button"
                                                aria-haspopup="listbox" aria-expanded="false">
                                                <!-- Absolute Icon (Languages) -->
                                                <div class="selected-icon">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="16" viewBox="0 0 44 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-audio-language-horizontal">

                                                                <!-- PERSON + AUDIO (giữ nguyên, đã dịch trái) -->
                                                                <g fill="currentColor" stroke="none" transform="translate(-2 0)">
                                                                <path d="M19.4 .2C19.29 .27 19.20 .37 19.13 .49C19.07 .60 19.02 .72 19.01 .85C18.99 .98 18.99 1.12 19.03 1.24C19.06 1.37 19.12 1.49 19.2 1.6L20.8 .4C20.64 .18 20.40 .04 20.14 .01C19.87 -0.02 19.61 .04 19.4 .2ZM20.8 .4L20 1L19.2 1.59C20.37 3.16 21.00 5.06 21.00 7.01C20.99 8.97 20.35 10.87 19.17 12.42C19.01 12.64 18.94 12.90 18.98 13.16C19.02 13.43 19.16 13.66 19.37 13.83C19.58 13.99 19.84 14.05 20.11 14.02C20.37 13.98 20.61 13.84 20.77 13.63C22.21 11.73 22.99 9.41 23 7.02C23.00 4.63 22.23 2.31 20.8 .4ZM10 2C8.67 2 7.40 2.52 6.46 3.46C5.52 4.40 5 5.67 5 7C5 8.32 5.52 9.59 6.46 10.53C7.40 11.47 8.67 12 10 12C11.32 12 12.59 11.47 13.53 10.53C14.47 9.59 15 8.32 15 7C15 5.67 14.47 4.40 13.53 3.46C12.59 2.52 11.32 2 10 2ZM16.17 2.29C15.97 2.48 15.86 2.73 15.86 2.99C15.85 3.26 15.95 3.51 16.14 3.71C16.98 4.58 17.44 5.68 17.49 6.80L17.5 7.02C17.49 8.22 17.01 9.40 16.10 10.32C15.92 10.51 15.83 10.77 15.83 11.03C15.84 11.29 15.95 11.53 16.13 11.71C16.32 11.90 16.57 12.00 16.83 12.00C17.09 12.00 17.34 11.90 17.53 11.72C18.78 10.44 19.49 8.77 19.5 7.03L19.49 6.71C19.42 5.09 18.74 3.53 17.58 2.32C17.49 2.23 17.38 2.15 17.26 2.10C17.14 2.05 17.01 2.02 16.88 2.01C16.75 2.01 16.62 2.03 16.49 2.08C16.37 2.13 16.26 2.20 16.17 2.29ZM10.39 13.01L10 13C8.01 12.99 6.10 13.73 4.63 15.06L4.34 15.34C3.60 16.08 3.01 16.96 2.60 17.93C2.20 18.90 1.99 19.94 2 21C2 21.26 2.10 21.51 2.29 21.70C2.48 21.89 2.73 22 3 22C3.26 22 3.51 21.89 3.70 21.70C3.89 21.51 4 21.26 4 21C4.00 19.40 4.63 17.88 5.75 16.75L5.97 16.55C7.07 15.55 8.51 15 10 15L10.29 15.00C11.78 15.08 13.18 15.70 14.24 16.75L14.44 16.97C15.44 18.07 16 19.51 16 21C16 21.26 16.10 21.51 16.29 21.70C16.48 21.89 16.73 22 17 22C17.26 22 17.51 21.89 17.70 21.70C17.89 21.51 18 21.26 18 21C18.00 19.01 17.26 17.10 15.93 15.63L15.65 15.34C14.25 13.93 12.37 13.10 10.39 13.01Z"></path>
                                                                </g>

                                                                <!-- LANGUAGE ICON (gần hơn ~1.5x so với trước) -->
                                                                <!-- trước: translate(26.8 1.6) -->
                                                                <g transform="translate(23.8 1.6) scale(0.75)">
                                                                    <path d="m5 8 6 6"></path>
                                                                    <path d="m4 14 6-6 2-3"></path>
                                                                    <path d="M2 5h12"></path>
                                                                    <path d="M7 2h1"></path>
                                                                    <path d="m22 22-5-10-5 10"></path>
                                                                    <path d="M14 18h6"></path>
                                                                </g>
                                                                </svg>
                                                </div>
                                                <div class="selected-content">
                                                    <span class="selected-text">Original</span>
                                                </div>
                                                <svg class="dropdown-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <path d="M6 9l6 6 6-6" />
                                                </svg>
                                            </div>
                                            <div class="dropdown-menu hidden">
                                                <div class="dropdown-search">
                                                    <input type="text" placeholder="Search..." aria-label="Search language">
                                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="search-icon">
                                                        <circle cx="11" cy="11" r="8"></circle>
                                                        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                                                    </svg>
                                                </div>
                                                <div class="dropdown-options" role="listbox"></div>
                                            </div>
                                            <input type="hidden" id="audio-track-value" value="original" name="audioTrack">
                                        </div>
                                    </div>
                                    <script>(function(){try{var p=JSON.parse(localStorage.getItem('y2mate_format_preferences'));if(!p)return;var s=p.selectedFormat==='mp4'?document.getElementById('quality-select-mp4'):document.getElementById('quality-select-mp3');if(!s)return;var v;if(p.selectedFormat==='mp4'){var vq=p.videoQuality||'720p';v=(vq==='webm'||vq==='mkv')?vq:'mp4-'+vq.replace('p','')}else{var af=p.audioFormat||'mp3';v=(af==='mp3')?'mp3-'+(p.audioBitrate||'128'):af}s.value=v}catch(e){}})()</script>
                                </div>
                                <button type="submit" class="btn-convert">
                                    <span>{{ base.hero.convertButton }}</span>
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M5 12h14" />
                                        <path d="M12 5l7 7-7 7" />
                                    </svg>
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
                <div id="error-message" class="error-message"></div>
            </div>

            <div id="result-view" class="hidden fade-in">
                <div id="content-area"></div>
            </div>
        </div>
    </div>
</section>

<!-- Search Results Section -->
<section id="search-results-section" style="display: none;">
    <div class="container">
        <div id="search-results-container"></div>
    </div>
</section>

<!-- SEO / TEXT CONTENT -->
<section class="seo-section container">
    <div class="seo-container">
        <article class="prose">
            <h2>{{ page.content.mainTitle }}</h2>
            <p>{{ page.content.intro1 | localizeLinks(lang) | safe }}</p>
            <p>{{ page.content.intro2 | localizeLinks(lang) | safe }}</p>

            <h2>{{ page.content.whatIsTitle }}</h2>
            {{ page.content.whatIsText | localizeLinks(lang) | safe }}

            <h2>{{ page.whyChoose.title }}</h2>
            <p>{{ page.whyChoose.intro | localizeLinks(lang) | safe }}</p>
            <ul>
                {%- for reason in page.whyChoose.reasons %}
                <li><strong>{{ reason.title }}:</strong> {{ reason.text }}</li>
                {%- endfor %}
            </ul>

            <h2>{{ page.instructions.title }}</h2>
            <ol>
                {%- for step in page.instructions.steps %}
                <li>{{ step }}</li>
                {%- endfor %}
            </ol>

            <h2>{{ page.content.comparisonTitle }}</h2>
            {{ page.content.comparisonText | localizeLinks(lang) | safe }}

            {%- if page.faqs and page.faqs.items %}
            <div id="faq" class="faq-section">
                <h2 class="faq-title">
                    <span class="faq-icon">?</span>
                    {{ page.faqs.title }}
                </h2>
                <div class="faq-grid">
                    {%- for faq in page.faqs.items %}
                    <div class="faq-item">
                        <h3 class="faq-question">{{ faq.question }}</h3>
                        <p class="faq-answer">{{ faq.answer | localizeLinks(lang) | safe }}</p>
                    </div>
                    {%- endfor %}
                </div>
            </div>
            {%- endif %}
        </article>
    </div>
</section>
