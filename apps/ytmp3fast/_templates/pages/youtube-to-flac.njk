---
layout: base.njk
pagination:
  data: flacPages
  size: 1
  alias: pageInfo
eleventyComputed:
  permalink: "{{ pageInfo.permalink }}"
  lang: "{{ pageInfo.lang }}"
  pageKey: "{{ pageInfo.pageKey }}"
---
{%- set base = i18nBase[lang] or i18nBase['en'] -%}
{%- set page = i18nPages[pageKey][lang] or i18nPages[pageKey].en -%}
{%- set langPrefix = '' if (lang == 'en' or not lang) else '/' + lang -%}

<!-- HERO SECTION -->
<section class="hero-section">
    <div class="decorative-glow"></div>
    <div class="hero-container">
        <div class="hero-card">
            <div id="hero-header" class="hero-header">
                <h1>{{ page.hero.title }} <span class="title-accent" id="title-format">{{ page.hero.titleAccent }}</span></h1>
            </div>

            <div id="search-view" class="fade-in">
                <p class="hero-subtitle">{{ page.hero.subtitle | safe }}</p>

                <form id="downloadForm" class="form-container">
                    <div class="input-group">
                        <div class="input-wrapper" id="input-wrapper">
                            <input type="text" id="videoUrl" class="video-input"
                                placeholder="{{ base.hero.placeholder }}" autocomplete="off">
                            <div class="input-actions">
                                <button type="button" id="input-action-button" class="btn-paste" data-action="paste">
                                    <svg class="paste-icon" width="14" height="14" viewBox="0 0 24 24"
                                        fill="none" stroke="currentColor" stroke-width="2">
                                        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                                        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                                    </svg>
                                    <span class="btn-state--paste">{{ base.hero.pasteButton }}</span>
                                    <svg class="clear-icon hidden" width="18" height="18" viewBox="0 0 24 24"
                                        fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                                        <line x1="18" y1="6" x2="6" y2="18"></line>
                                        <line x1="6" y1="6" x2="18" y2="18"></line>
                                    </svg>
                                    <span class="btn-state--clear hidden">{{ base.hero.clearButton }}</span>
                                </button>
                            </div>
                        </div>
                        <div id="suggestion-container" class="suggestion-container"></div>
                    </div>

                    <div id="format-selector-container">
                        <div class="format-selector-wrapper">
                            <div class="format-selector">
                                <div class="format-toggle">
                                    <button type="button" class="format-btn active" data-format="mp3">MP3</button>
                                    <button type="button" class="format-btn" data-format="mp4">MP4</button>
                                </div>
                                <div class="quality-wrapper">
                                    <div class="quality-dropdown-wrapper">
                                        <select id="quality-select-mp3" class="quality-select quality-select--mp3"
                                            aria-label="Audio quality" data-quality-select>
                                            <option value="flac" selected>FLAC - Lossless</option>
                                            <option value="wav">WAV - Lossless</option>
                                            <option value="mp3-320">MP3 - 320kbps</option>
                                            <option value="mp3-192">MP3 - 192kbps</option>
                                            <option value="mp3-128">MP3 - 128kbps</option>
                                            <option value="m4a">M4A</option>
                                            <option value="opus">Opus</option>
                                            <option value="ogg">OGG</option>
                                        </select>
                                        <select id="quality-select-mp4" class="quality-select quality-select--mp4"
                                            aria-label="Video quality" data-quality-select>
                                            <option value="mp4-1080">MP4 - 1080p</option>
                                            <option value="mp4-720" selected>MP4 - 720p</option>
                                            <option value="mp4-480">MP4 - 480p</option>
                                            <option value="mp4-360">MP4 - 360p</option>
                                            <option value="mp4-240">MP4 - 240p</option>
                                            <option value="mp4-144">MP4 - 144p</option>
                                            <option value="webm">WEBM</option>
                                            <option value="mkv">MKV</option>
                                        </select>
                                    </div>
                                    <div class="select-arrow">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M6 9l6 6 6-6" />
                                        </svg>
                                    </div>
                                </div>
                                <button type="submit" class="btn-convert">
                                    <span>{{ base.hero.convertButton }}</span>
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M5 12h14" />
                                        <path d="M12 5l7 7-7 7" />
                                    </svg>
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
                <div id="error-message" class="error-message"></div>
            </div>

            <div id="result-view" class="hidden fade-in">
                <div id="content-area"></div>
            </div>
        </div>
    </div>
</section>

<!-- Search Results Section -->
<section id="search-results-section" style="display: none;">
    <div class="container">
        <div id="search-results-container"></div>
    </div>
</section>

<!-- SEO / TEXT CONTENT -->
<section class="seo-section container">
    <div class="seo-container">
        <article class="prose">
            <h2>{{ page.content.mainTitle }}</h2>
            <p>{{ page.content.intro1 | localizeLinks(lang) | safe }}</p>
            <p>{{ page.content.intro2 | localizeLinks(lang) | safe }}</p>

            <h2>{{ page.content.whatIsTitle }}</h2>
            {{ page.content.whatIsText | localizeLinks(lang) | safe }}

            <h2>{{ page.whyChoose.title }}</h2>
            <ul>
                {%- for reason in page.whyChoose.reasons %}
                <li><strong>{{ reason.title }}:</strong> {{ reason.text }}</li>
                {%- endfor %}
            </ul>

            <h2>{{ page.instructions.title }}</h2>
            <ol>
                {%- for step in page.instructions.steps %}
                <li>{{ step }}</li>
                {%- endfor %}
            </ol>

            {%- if page.faqs and page.faqs.items %}
            <div id="faq" class="faq-section">
                <h2 class="faq-title">
                    <span class="faq-icon">?</span>
                    {{ page.faqs.title }}
                </h2>
                <div class="faq-grid">
                    {%- for faq in page.faqs.items %}
                    <div class="faq-item">
                        <h3 class="faq-question">{{ faq.question }}</h3>
                        <p class="faq-answer">{{ faq.answer | localizeLinks(lang) | safe }}</p>
                    </div>
                    {%- endfor %}
                </div>
            </div>
            {%- endif %}
        </article>
    </div>
</section>
