{#- Helper: Get language-aware URL -#}
{%- macro getUrl(slug) -%}
{%- if lang == 'en' or not lang -%}/{{ slug }}{%- else -%}/{{ lang }}/{{ slug }}{%- endif -%}
{%- endmacro -%}

{%- set homeUrl = '/' if (lang == 'en' or not lang) else '/' + lang + '/' -%}
{%- set flagMap = {
  'en': 'us',
  'ar': 'sa',
  'bn': 'bd',
  'de': 'de',
  'es': 'es',
  'fr': 'fr',
  'hi': 'in',
  'id': 'id',
  'it': 'it',
  'ja': 'jp',
  'ko': 'kr',
  'my': 'mm',
  'ms': 'my',
  'pt': 'pt',
  'ru': 'ru',
  'th': 'th',
  'tr': 'tr',
  'ur': 'pk',
  'vi': 'vn'
} -%}
{%- set currentLang = lang or 'en' -%}
{%- set currentFlag = flagMap[currentLang] or 'us' -%}

<!-- HEADER -->
<header id="main-header">
    <div class="container max-w-5xl header-container">
        <!-- Logo -->
        <a href="{{ homeUrl }}" class="logo">
            <div class="logo-text">YTMP3fast</div>
        </a>

        <!-- Desktop Nav -->
        <div class="desktop-nav">
            <nav class="nav-links">
                <a href="{{ homeUrl }}" class="nav-link{% if pageKey == 'index' %} active{% endif %}">{{ base.nav.home }}</a>
                <a href="/about" class="nav-link">{{ base.nav.about }}</a>
            </nav>

            <div class="nav-divider"></div>

            <!-- Language Selector -->
            <div class="lang-selector">
                <button class="lang-button">
                    <img class="lang-flag" src="/assest/flat-svg/{{ currentFlag }}.{{ 'png' if currentFlag == 'us' else 'svg' }}" alt="" aria-hidden="true" width="18" height="14">
                </button>
                <!-- Language Dropdown -->
                <div class="lang-dropdown">
                    {%- for langItem in site.languages %}
                    {%- if langItem.isDefault %}
                    {%- set langUrl = '/' if pageKey == 'index' else '/' + pageInfo.slug %}
                    {%- else %}
                    {%- set langUrl = '/' + langItem.code + '/' if pageKey == 'index' else '/' + langItem.code + '/' + pageInfo.slug %}
                    {%- endif %}
                    {%- set optionFlag = flagMap[langItem.code] or 'us' %}
                    <a href="{{ langUrl }}" class="lang-option{% if langItem.code == lang %} active{% endif %}">
                        <img class="lang-flag" src="/assest/flat-svg/{{ optionFlag }}.{{ 'png' if optionFlag == 'us' else 'svg' }}" alt="" aria-hidden="true"
                            loading="lazy" width="18" height="14">
                        <span>{{ langItem.name }}</span>
                    </a>
                    {%- endfor %}
                </div>
            </div>
        </div>

        <!-- Mobile Menu Button -->
        <button id="mobile-menu-btn" class="mobile-menu-btn" aria-label="Open menu">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <line x1="3" y1="12" x2="21" y2="12" />
                <line x1="3" y1="6" x2="21" y2="6" />
                <line x1="3" y1="18" x2="21" y2="18" />
            </svg>
        </button>
    </div>
</header>

