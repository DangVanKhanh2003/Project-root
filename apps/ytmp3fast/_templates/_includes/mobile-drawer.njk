{%- set homeUrl = '/' if (lang == 'en' or not lang) else '/' + lang + '/' -%}
{%- set langPrefix = '' if (lang == 'en' or not lang) else '/' + lang -%}
{%- set flagMap = {
  'en': 'us',
  'ar': 'sa',
  'bn': 'bd',
  'de': 'de',
  'es': 'es',
  'fr': 'fr',
  'hi': 'in',
  'id': 'id',
  'it': 'it',
  'ja': 'jp',
  'ko': 'kr',
  'my': 'mm',
  'ms': 'my',
  'pt': 'pt',
  'ru': 'ru',
  'th': 'th',
  'tr': 'tr',
  'ur': 'pk',
  'vi': 'vn'
} -%}
{%- set currentLang = lang or 'en' -%}
{%- set currentFlag = flagMap[currentLang] or 'us' -%}

<!-- MOBILE DRAWER -->
<div id="mobile-drawer" class="mobile-drawer" hidden>
    <div id="mobile-drawer-content" class="drawer-content">
        <div class="drawer-header">
            <span class="drawer-logo">ytmp3fast.com</span>
            <button id="close-drawer-btn" class="close-drawer-btn" aria-label="Close menu">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18" />
                    <line x1="6" y1="6" x2="18" y2="18" />
                </svg>
            </button>
        </div>
        <div class="drawer-menu">
            <a href="{{ langPrefix }}/youtube-to-mp3-320kbps-converter" class="drawer-sublink">{{ base.drawer.mp3320 }}</a>
            <a href="{{ langPrefix }}/youtube-to-wav-converter" class="drawer-sublink">{{ base.drawer.wav }}</a>
            <a href="{{ langPrefix }}/youtube-to-flac-converter" class="drawer-sublink">{{ base.drawer.flac }}</a>
            <a href="{{ langPrefix }}/youtube-to-m4a-converter" class="drawer-sublink">{{ base.drawer.m4a }}</a>
            <div class="drawer-divider"></div>
            <a href="{{ homeUrl }}" class="drawer-sublink">{{ base.nav.home }}</a>
            <a href="/about" class="drawer-sublink">{{ base.nav.about }}</a>
            <div class="drawer-divider"></div>
            <div class="drawer-lang-selector">
                <button class="drawer-lang-button">
<span>{{ currentLang | upper }}</span>
</button>
                <div class="drawer-lang-dropdown">
                    {%- for langItem in site.languages %}
                    {%- if langItem.isDefault %}
                    {%- set langUrl = '/' if pageKey == 'index' else '/' + pageInfo.slug %}
                    {%- else %}
                    {%- set langUrl = '/' + langItem.code + '/' if pageKey == 'index' else '/' + langItem.code + '/' + pageInfo.slug %}
                    {%- endif %}
                    {%- set optionFlag = flagMap[langItem.code] or 'us' %}
                    <a href="{{ langUrl }}" class="drawer-lang-option{% if langItem.code == lang %} active{% endif %}">
                        <img class="lang-flag" src="/assest/flat-svg/{{ optionFlag }}.svg" alt="" aria-hidden="true"
                            loading="lazy" width="18" height="14">
                        <span>{{ langItem.name }}</span>
                    </a>
                    {%- endfor %}
                </div>
            </div>
        </div>
    </div>
</div>


