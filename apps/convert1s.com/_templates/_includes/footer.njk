            <a href="{{ langPrefix }}/youtube-to-mp3" style="color: inherit; text-decoration: none;">{{ base.footer.links.youtubeToMp3 or 'YouTube to MP3' }}</a>
            <a href="{{ langPrefix }}/youtube-to-mp4" style="color: inherit; text-decoration: none;">{{ base.footer.links.youtubeToMp4 or 'YouTube to MP4' }}</a>
