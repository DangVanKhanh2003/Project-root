            <a href="{{ langPrefix }}/tiktok-downloader" style="color: inherit; text-decoration: none;">{{ base.footer.links.tiktokDownloader or 'TikTok Downloader' }}</a>
            <a href="{{ langPrefix }}/facebook-downloader" style="color: inherit; text-decoration: none;">{{ base.footer.links.facebookDownloader or 'Facebook Downloader' }}</a>
            <a href="{{ langPrefix }}/instagram-downloader" style="color: inherit; text-decoration: none;">{{ base.footer.links.instagramDownloader or 'Instagram Downloader' }}</a>
            <a href="{{ langPrefix }}/twitter-downloader" style="color: inherit; text-decoration: none;">{{ base.footer.links.twitterDownloader or 'Twitter Downloader' }}</a>
            <a href="{{ langPrefix }}/vimeo-downloader" style="color: inherit; text-decoration: none;">{{ base.footer.links.vimeoDownloader or 'Vimeo Downloader' }}</a>
            <a href="{{ langPrefix }}/linkedin-downloader" style="color: inherit; text-decoration: none;">{{ base.footer.links.linkedinDownloader or 'LinkedIn Downloader' }}</a>
            <a href="{{ langPrefix }}/bili-downloader" style="color: inherit; text-decoration: none;">{{ base.footer.links.biliDownloader or 'Bilibili Downloader' }}</a>
            <a href="{{ langPrefix }}/kwai-downloader" style="color: inherit; text-decoration: none;">{{ base.footer.links.kwaiDownloader or 'Kwai Downloader' }}</a>
            <a href="{{ langPrefix }}/vk-downloader" style="color: inherit; text-decoration: none;">{{ base.footer.links.vkDownloader or 'VK Downloader' }}</a>
