{%- set langPrefix = '' if (lang == 'en' or not lang) else '/' + lang -%}
{%- set homeUrl = '/' if (lang == 'en' or not lang) else '/' + lang + '/' -%}

<!-- FOOTER -->
<footer class="footer-container">
    <a href="{{ homeUrl }}" class="logo" style="justify-content:center; margin-bottom: 20px;">
        <div class="logo-icon">MP3</div>
        <span class="logo-text">MP3Converter</span>
    </a>
    <nav class="footer-nav">
        <a href="/about" class="footer-link">{{ base.footer.about or 'About' }}</a>
        <a href="/contact" class="footer-link">{{ base.footer.contact }}</a>
        <a href="/faq" class="footer-link">{{ base.footer.faq }}</a>
    </nav>
    <div class="footer-legal">
        <a href="/privacy-policy" class="footer-link">{{ base.footer.privacyPolicy }}</a>
        <span style="margin: 0 10px; color: var(--border-primary);">|</span>
        <a href="/terms-of-use" class="footer-link">{{ base.footer.terms }}</a>
    </div>
    <p class="footer-copyright">{{ base.footer.copyright | replace('YTMP3.my', 'MP3Converter') | replace('ytmp3.my', 'MP3Converter') }}</p>
</footer>
