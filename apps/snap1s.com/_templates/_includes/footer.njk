{%- set base = i18nBase[lang] or i18nBase['en'] -%}
{%- set langPrefix = '' if (lang == 'en' or not lang) else '/' + lang -%}

<footer>
    <div class="container">
        <div class="footer-links" style="display: flex; justify-content: center; gap: 20px; margin-bottom: 20px; flex-wrap: wrap;">
            <a href="{{ langPrefix }}/tiktok-downloader" style="color: inherit; text-decoration: none;">{{ base.footer.links.tiktokDownloader or 'TikTok Downloader' }}</a>
            <a href="{{ langPrefix }}/vimeo-downloader" style="color: inherit; text-decoration: none;">{{ base.footer.links.vimeoDownloader or 'Vimeo Downloader' }}</a>
            <a href="{{ langPrefix }}/youtube-downloader" style="color: inherit; text-decoration: none;">{{ base.footer.links.youtubeDownloader or 'YouTube Downloader' }}</a>
        </div>
        <div class="copyright">{{ base.footer.copyright }}</div>
    </div>
</footer>
