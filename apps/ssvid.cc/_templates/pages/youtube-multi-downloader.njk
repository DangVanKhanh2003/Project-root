---
layout: base.njk
pagination:
  data: youtubeMultiDownloaderPages
  size: 1
  alias: pageInfo
eleventyComputed:
  permalink: "{{ pageInfo.permalink }}"
  lang: "{{ pageInfo.lang }}"
  pageKey: "{{ pageInfo.pageKey }}"
  pageScript: "/src/multi-downloader-main.ts"
  pageStyles:
    - "/src/styles/features/multiple-downloader-v2.css"
---
{%- set base = i18nBase[lang] or i18nBase['en'] -%}
{%- set page = i18nPages[pageKey][lang] or i18nPages[pageKey].en -%}
{%- set langPrefix = '' if (lang == 'en' or not lang) else '/' + lang -%}

<!-- HERO SECTION -->
<section class="hero-section">
    <div class="container hero-container">
        <div id="hero-header" class="hero-header">
            <h1 class="title-hero">{{ page.hero.title }}</h1>
            <p class="subtitle-hero">{{ page.hero.subtitle }}</p>
        </div>

        <!-- Multi Download Form -->
        <div id="multi-download-form" class="multiple-download-card">
            <!-- URL Input Area -->
            <div class="urls-input-container">
                <textarea id="urlsInput" class="urls-textarea"
                    placeholder="{{ page.form.textareaPlaceholder }}" rows="5"></textarea>
            </div>

            <!-- Global Settings Row -->
            <div id="multi-download-form-actions">
                <div class="multi-format-selector-wrapper">
                    <div class="multi-format-selector">
                        <div class="multi-format-toggle">
                            <button type="button" class="multi-format-btn active"
                                data-format="mp4">{{ base.hero.formatMp4 }}</button>
                            <button type="button" class="multi-format-btn"
                                data-format="mp3">{{ base.hero.formatMp3 }}</button>
                        </div>
                        <div class="multi-quality-wrapper">
                            <div class="multi-quality-dropdown-wrapper">
                                <select id="multi-quality-select-mp3"
                                    class="multi-quality-select multi-quality-select--mp3"
                                    aria-label="Audio quality" data-quality-select style="display: none;">
                                    <option value="mp3-128" selected>MP3 - 128kbps</option>
                                    <option value="mp3-320">MP3 - 320kbps</option>
                                    <option value="ogg">OGG</option>
                                    <option value="wav">WAV - Lossless</option>
                                    <option value="opus">Opus</option>
                                    <option value="m4a">M4A</option>
                                </select>
                                <select id="multi-quality-select-mp4"
                                    class="multi-quality-select multi-quality-select--mp4"
                                    aria-label="Video quality" data-quality-select>
                                    <option value="mp4-1080">MP4 - 1080p</option>
                                    <option value="mp4-720" selected>MP4 - 720p</option>
                                    <option value="mp4-480">MP4 - 480p</option>
                                    <option value="mp4-360">MP4 - 360p</option>
                                    <option value="mp4-144">MP4 - 144p</option>
                                    <option value="webm">WEBM</option>
                                    <option value="mkv">MKV</option>
                                </select>
                                <div class="multi-select-arrow">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                        stroke="currentColor" stroke-width="2">
                                        <path d="M6 9l6 6 6-6" />
                                    </svg>
                                </div>
                            </div>
                            <div class="multi-audio-dropdown-wrapper">
                                <div class="custom-dropdown" id="multi-audio-track-dropdown">
                                    <div class="dropdown-trigger" tabindex="0" role="button"
                                        aria-haspopup="listbox" aria-expanded="false">
                                        <div class="selected-icon">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="16"
                                                viewBox="0 0 44 24" fill="none" stroke="currentColor"
                                                stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                                class="icon-audio-language-horizontal">
                                                <g fill="currentColor" stroke="none" transform="translate(-2 0)">
                                                    <path
                                                        d="M19.4 .2C19.29 .27 19.20 .37 19.13 .49C19.07 .60 19.02 .72 19.01 .85C18.99 .98 18.99 1.12 19.03 1.24C19.06 1.37 19.12 1.49 19.2 1.6L20.8 .4C20.64 .18 20.40 .04 20.14 .01C19.87 -0.02 19.61 .04 19.4 .2ZM20.8 .4L20 1L19.2 1.59C20.37 3.16 21.00 5.06 21.00 7.01C20.99 8.97 20.35 10.87 19.17 12.42C19.01 12.64 18.94 12.90 18.98 13.16C19.02 13.43 19.16 13.66 19.37 13.83C19.58 13.99 19.84 14.05 20.11 14.02C20.37 13.98 20.61 13.84 20.77 13.63C22.21 11.73 22.99 9.41 23 7.02C23.00 4.63 22.23 2.31 20.8 .4ZM10 2C8.67 2 7.40 2.52 6.46 3.46C5.52 4.40 5 5.67 5 7C5 8.32 5.52 9.59 6.46 10.53C7.40 11.47 8.67 12 10 12C11.32 12 12.59 11.47 13.53 10.53C14.47 9.59 15 8.32 15 7C15 5.67 14.47 4.40 13.53 3.46C12.59 2.52 11.32 2 10 2ZM16.17 2.29C15.97 2.48 15.86 2.73 15.86 2.99C15.85 3.26 15.95 3.51 16.14 3.71C16.98 4.58 17.44 5.68 17.49 6.80L17.5 7.02C17.49 8.22 17.01 9.40 16.10 10.32C15.92 10.51 15.83 10.77 15.83 11.03C15.84 11.29 15.95 11.53 16.13 11.71C16.32 11.90 16.57 12.00 16.83 12.00C17.09 12.00 17.34 11.90 17.53 11.72C18.78 10.44 19.49 8.77 19.5 7.03L19.49 6.71C19.42 5.09 18.74 3.53 17.58 2.32C17.49 2.23 17.38 2.15 17.26 2.10C17.14 2.05 17.01 2.02 16.88 2.01C16.75 2.01 16.62 2.03 16.49 2.08C16.37 2.13 16.26 2.20 16.17 2.29ZM10.39 13.01L10 13C8.01 12.99 6.10 13.73 4.63 15.06L4.34 15.34C3.60 16.08 3.01 16.96 2.60 17.93C2.20 18.90 1.99 19.94 2 21C2 21.26 2.10 21.51 2.29 21.70C2.48 21.89 2.73 22 3 22C3.26 22 3.51 21.89 3.70 21.70C3.89 21.51 4 21.26 4 21C4.00 19.40 4.63 17.88 5.75 16.75L5.97 16.55C7.07 15.55 8.51 15 10 15L10.29 15.00C11.78 15.08 13.18 15.70 14.24 16.75L14.44 16.97C15.44 18.07 16 19.51 16 21C16 21.26 16.10 21.51 16.29 21.70C16.48 21.89 16.73 22 17 22C17.26 22 17.51 21.89 17.70 21.70C17.89 21.51 18 21.26 18 21C18.00 19.01 17.26 17.10 15.93 15.63L15.65 15.34C14.25 13.93 12.37 13.10 10.39 13.01Z">
                                                    </path>
                                                </g>
                                                <g transform="translate(23.8 1.6) scale(0.75)">
                                                    <path d="m5 8 6 6"></path>
                                                    <path d="m4 14 6-6 2-3"></path>
                                                    <path d="M2 5h12"></path>
                                                    <path d="M7 2h1"></path>
                                                    <path d="m22 22-5-10-5 10"></path>
                                                    <path d="M14 18h6"></path>
                                                </g>
                                            </svg>
                                        </div>
                                        <div class="selected-content">
                                            <span class="selected-text">{{ page.form.audioTrackLabel }}</span>
                                        </div>
                                        <svg class="dropdown-arrow" width="16" height="16"
                                            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M6 9l6 6 6-6" />
                                        </svg>
                                    </div>

                                    <div class="dropdown-menu hidden">
                                        <div class="dropdown-search">
                                            <input type="text" placeholder="{{ base.hero.searchPlaceholder }}"
                                                aria-label="Search language">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2" class="search-icon">
                                                <circle cx="11" cy="11" r="8"></circle>
                                                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                                            </svg>
                                        </div>
                                        <div class="dropdown-options" role="listbox">
                                        </div>
                                    </div>
                                    <input type="hidden" id="multi-audio-track-value" value="original"
                                        name="audioTrack">
                                </div>
                            </div>
                        </div>
                        <button type="button" id="addUrlsBtn" class="multi-btn-convert">
                            <span>{{ page.form.convertButton }}</span>
                        </button>
                    </div>
                </div>
            </div>
            <div id="error-message" class="error-message" role="alert" aria-live="polite"></div>
        </div>
    </div>
</section>

<!-- Video List Section -->
<section class="video-list-section">
    <div class="container">
        <div id="multiple-downloads-container" class="multiple-downloads-container" style="display: none;">
            <!-- Video items will be rendered by MultipleDownloadRenderer -->
        </div>
    </div>
</section>

<!-- OVERVIEW SECTION -->
<section id="about" class="overview-section" aria-label="SSVID overview">
    <div class="container overview-container">
        <div class="overview-info">
            <div class="overview-badge">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                    class="lucide lucide-shield-check" aria-hidden="true">
                    <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path>
                    <path d="m9 12 2 2 4-4"></path>
                </svg>
                <span>{{ base.overview.badge }}</span>
            </div>
            <h2 class="overview-title">{{ page.content.intro.title }}</h2>
            <p class="overview-desc">{{ page.content.intro.description | safe }}</p>
        </div>

        <div class="overview-steps-card">
            <h2 class="steps-card-title">{{ page.overview.howTo.title }}</h2>
            <div class="stepper">
                {% for step in page.overview.howTo.steps %}
                <div class="step-item">
                    <div class="step-circle">{{ loop.index }}</div>
                    <div class="step-text">
                        <h3>{{ step.title }}</h3>
                        <p>{{ step.description }}</p>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</section>

<!-- Content Section -->
<section class="content-section content-section--white">
    <div class="container">
        <h2 class="titles">{{ page.content.whyUse.title }}</h2>
        <p>{{ page.content.whyUse.description | safe }}</p>

        <h2 class="titles">{{ page.content.supportedFormats.title }}</h2>
        <p>{{ page.content.supportedFormats.description | safe }}</p>

        <h2 class="titles">{{ page.content.comparison.title }}</h2>
        {% for section in page.content.comparison.items %}
        <div class="subsection">
            <h3>{{ section.title }}</h3>
            <p>{{ section.description | localizeLinks(langPrefix) | safe }}</p>
        </div>
        {% endfor %}

        <h2 class="titles">{{ page.content.whenUse.title }}</h2>
        {% for section in page.content.whenUse.items %}
        <div class="subsection">
            <h3>{{ section.title }}</h3>
            <p>{{ section.description | safe }}</p>
        </div>
        {% endfor %}
    </div>
</section>

<!-- FAQ Section -->
<section id="faq" class="content-section content-section--gray faq-section">
    <div class="container">
        <h2 class="titles">{{ page.faqs.title }}</h2>
        {% for faq in page.faqs.items %}
        <div class="faq-item">
            <h3>{{ faq.question }}</h3>
            <p>{{ faq.answer | safe }}</p>
        </div>
        {% endfor %}
    </div>
</section>
