{%- set base = i18nBase[lang] or i18nBase['en'] -%}
{%- set pageData = i18nPages[pageKey or 'index'][lang or 'en'] -%}
{%- set seo = pageData.seo -%}

{#- Language code: en, vi, ar (2 chars) - Used for: HTML lang, URLs, JSON-LD -#}
{%- set langCode = lang or 'en' -%}

{#- Locale code: en_US, vi_VN (full format) - ONLY for Open Graph tags -#}
{%- set localeMap = {
  en: 'en_US',
  ar: 'ar_SA',
  bn: 'bn_BD',
  de: 'de_DE',
  es: 'es_ES',
  fr: 'fr_FR',
  hi: 'hi_IN',
  id: 'id_ID',
  it: 'it_IT',
  ja: 'ja_JP',
  ko: 'ko_KR',
  ms: 'ms_MY',
  my: 'my_MM',
  pt: 'pt_BR',
  ru: 'ru_RU',
  th: 'th_TH',
  tr: 'tr_TR',
  ur: 'ur_PK',
  vi: 'vi_VN',
  'zh-cn': 'zh_CN',
  'zh-tw': 'zh_TW',
  tl: 'tl_PH'
} -%}
{%- set ogLocale = localeMap[langCode] or 'en_US' -%}

{#- RTL languages -#}
{%- set rtlLanguages = ['ar', 'ur'] -%}

{#- URL prefix for non-English pages -#}
{%- set langPrefix = '' if (langCode == 'en') else '/' + langCode -%}
<!DOCTYPE html>
<html lang="{{ langCode }}"{% if langCode in rtlLanguages %} dir="rtl"{% endif %}>

<head>
    <meta name="robots" content="index, follow">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">
    <meta charset="UTF-8">

    <!-- SEO Metadata -->
    <title>{{ seo.title }}</title>
    <meta name="description" content="{{ seo.description }}">
    {#- cleanUrl: only index ends with / (e.g., /, /vi/, but /youtube-to-mp3, /vi/youtube-to-mp3) -#}
    {%- set cleanUrl = page.url | replace('/index.html', '/') | replace('.html', '') -%}
    <link rel="canonical" href="{{ site.url }}{{ cleanUrl }}">

    {#- hreflang tags: only render when multiple languages are active -#}
    {%- if site.languages | length > 1 %}
    {%- set pageSlug = '' if pageKey == 'index' else pageKey -%}
    {%- for langItem in site.languages %}
    {%- if langItem.isDefault %}
    {%- set altUrl = '/' if pageSlug == '' else '/' + pageSlug %}
    {%- else %}
    {%- set altUrl = '/' + langItem.code + '/' if pageSlug == '' else '/' + langItem.code + '/' + pageSlug %}
    {%- endif %}
    <link rel="alternate" hreflang="{{ langItem.code }}" href="{{ site.url }}{{ altUrl }}" />
    {%- endfor %}
    <link rel="alternate" hreflang="x-default" href="{{ site.url }}{{ '/' if pageSlug == '' else '/' + pageSlug }}" />
    {%- endif %}

    <!-- Schema.org markup (2-char language code) -->
    <meta itemprop="name" content="{{ seo.schemaName }}" />
    <meta itemprop="description" content="{{ seo.schemaDescription }}">
    <meta itemprop="inLanguage" content="{{ langCode }}" />

    <!-- Open Graph / Facebook (FULL locale code required) -->
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="{{ site.name }}">
    <meta property="og:url" content="{{ site.url }}{{ cleanUrl }}">
    <meta property="og:title" content="{{ seo.ogTitle }}">
    <meta property="og:description" content="{{ seo.ogDescription }}">
    <meta property="og:image" content="{{ site.url }}/favicon-512x512.png">
    <meta property="og:image:alt" content="{{ seo.ogTitle }}">
    <meta property="og:locale" content="{{ ogLocale }}">

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content="{{ site.url }}{{ cleanUrl }}">
    <meta name="twitter:title" content="{{ seo.ogTitle }}">
    <meta name="twitter:description" content="{{ seo.ogDescription }}">
    <meta name="twitter:image" content="{{ site.url }}/favicon-512x512.png">

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/favicon.png" type="image/png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png">
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png">
    <link rel="icon" type="image/png" sizes="128x128" href="/favicon-128x128.png">
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512x512.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">

    <link rel="preload" href="/fonts/Fredoka_SemiCondensed-Bold.woff2?v=2" as="font" type="font/woff2" crossorigin>
    <style>
        @font-face {
            font-family: 'Fredoka SemiCondensed';
            src: url('/fonts/Fredoka_SemiCondensed-Bold.woff2?v=2') format('woff2');
            font-weight: 700;
            font-style: normal;
            font-display: swap;
        }
    </style>

    <!-- Critical: Read format preference before render to prevent FOUC -->
    <script>
        function setTheme(theme) {
            if (theme === 'dark') {
                document.documentElement.setAttribute('data-theme', 'dark');
            } else {
                document.documentElement.removeAttribute('data-theme');
            }
            try {
                localStorage.setItem('theme', theme);
            } catch (e) { }
        }

        (function () {
            try {
                var savedTheme = localStorage.getItem('theme');
                if (savedTheme === 'dark' || (!savedTheme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                    document.documentElement.setAttribute('data-theme', 'dark');
                }
            } catch (e) { }

            var f = 'mp4';
            try {
                var p = JSON.parse(localStorage.getItem('real-y2mate_format_preferences'));
                if (p && p.selectedFormat) f = p.selectedFormat;
            } catch (e) { }

            document.documentElement.dataset.format = f;
            document.write('<style>html[data-format="mp3"] .quality-select--mp4,html[data-format="mp3"] .multi-quality-select--mp4{display:none!important}html[data-format="mp3"] .quality-select--mp3,html[data-format="mp3"] .multi-quality-select--mp3{display:block!important}html[data-format="mp4"] .quality-select--mp3,html[data-format="mp4"] .multi-quality-select--mp3{display:none!important}html[data-format="mp4"] .quality-select--mp4,html[data-format="mp4"] .multi-quality-select--mp4{display:block!important}html[data-format="mp4"] .quality-select--mp4.quality-select--native-hidden,html[data-format="mp4"] .multi-quality-select--mp4.quality-select--native-hidden{display:none!important}</style>');
        })();
    </script>

    <!-- JSON-LD Structured Data -->
    {% include "json-ld.njk" %}
    {%- if pageStyles and pageStyles.length %}
    {%- for href in pageStyles %}
    <link rel="stylesheet" href="{{ href }}">
    {%- endfor %}
    {%- endif %}
    {%- if pageInlineStyles %}
    <style>
        {{ pageInlineStyles | safe }}
    </style>
    {%- endif %}
</head>

<body{% if bodyDataPage %} data-page="{{ bodyDataPage }}"{% endif %}>
    {# Include Header #}
    {% include "header.njk" %}

    {# Main Content #}
    <main>
        {{ content | safe }}
    </main>

    {# Include Footer #}
    {% include "footer.njk" %}

    <!-- Main TypeScript Entry -->
    {%- set pageScriptSrc = pageScript or '/src/main.ts' -%}
    <script type="module" src="{{ pageScriptSrc }}"></script>

   
</body>

</html>
