---
layout: base.njk
pagination:
  data: indexPages
  size: 1
  alias: pageInfo
eleventyComputed:
  permalink: "{{ pageInfo.permalink }}"
  lang: "{{ pageInfo.lang }}"
  pageKey: "{{ pageInfo.pageKey }}"
---
{%- set base = i18nBase[lang] or i18nBase['en'] -%}
{%- set page = i18nPages[pageKey][lang] or i18nPages[pageKey].en -%}
{%- set langPrefix = '' if (lang == 'en' or not lang) else '/' + lang -%}

<!-- HERO SECTION -->
<section class="hero-section">
    <div class="decorative-glow"></div>
    <div class="hero-container">
        <div class="hero-card">
            <div id="hero-header" class="hero-header">
                <h1>{{ page.hero.title }} <span class="text-accent">{{ page.hero.titleAccent }}</span></h1>
            </div>

            <div id="search-view" class="fade-in">
                <p class="hero-subtitle">{{ page.hero.subtitle }}</p>

                <form id="downloadForm" class="form-container">
                    <div class="input-group">
                        <div class="input-wrapper" id="input-wrapper">
                            <input type="text" id="videoUrl" class="video-input"
                                placeholder="{{ page.hero.placeholder or base.hero.placeholder }}" autocomplete="off">
                            <div class="input-actions">
                                <button type="button" id="input-action-button" class="btn-paste" data-action="paste">
                                    <svg class="paste-icon" width="14" height="14" viewBox="0 0 24 24"
                                        fill="none" stroke="currentColor" stroke-width="2">
                                        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                                        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                                    </svg>
                                    <span class="btn-state--paste">{{ base.hero.pasteButton }}</span>
                                    <svg class="clear-icon hidden" width="18" height="18" viewBox="0 0 24 24"
                                        fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                                        <line x1="18" y1="6" x2="6" y2="18"></line>
                                        <line x1="6" y1="6" x2="18" y2="18"></line>
                                    </svg>
                                    <span class="btn-state--clear hidden">{{ base.hero.clearButton }}</span>
                                </button>
                            </div>
                        </div>
                        <div id="suggestion-container" class="suggestion-container"></div>
                    </div>

                    <div id="format-selector-container">
                        <div class="format-selector-wrapper">
                            <div class="format-selector">
                                <div class="quality-wrapper">
                                    <input type="hidden" id="unified-format-select" name="format" value="video|mp4-2160" data-unified-select>
                                    <button type="button" class="quality-select custom-dropdown-trigger" aria-haspopup="listbox" aria-expanded="false">
                                        <span class="dropdown-selected-text">MP4 - 4K</span>
                                        <svg class="dropdown-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M6 9l6 6 6-6" />
                                        </svg>
                                    </button>
                                    <div class="custom-dropdown-menu" role="listbox" hidden>
                                        <div class="dropdown-group">
                                            <div class="dropdown-group-label">Video</div>
                                            <div class="dropdown-option selected" data-value="video|mp4-2160" role="option">MP4 - 4K</div>
                                            <div class="dropdown-option" data-value="video|mp4-1440" role="option">MP4 - 2K</div>
                                            <div class="dropdown-option" data-value="video|mp4-1080" role="option">MP4 - 1080p</div>
                                            <div class="dropdown-option" data-value="video|mp4-720" role="option">MP4 - 720p</div>
                                            <div class="dropdown-option" data-value="video|mp4-480" role="option">MP4 - 480p</div>
                                            <div class="dropdown-option" data-value="video|mp4-360" role="option">MP4 - 360p</div>
                                            <div class="dropdown-option" data-value="video|mp4-240" role="option">MP4 - 240p</div>
                                            <div class="dropdown-option" data-value="video|mp4-144" role="option">MP4 - 144p</div>
                                            <div class="dropdown-option" data-value="video|webm" role="option">WEBM</div>
                                            <div class="dropdown-option" data-value="video|mkv" role="option">MKV</div>
                                        </div>
                                        <div class="dropdown-group">
                                            <div class="dropdown-group-label">Audio</div>
                                            <div class="dropdown-option" data-value="audio|mp3-320" role="option">MP3 - 320kbps</div>
                                            <div class="dropdown-option" data-value="audio|mp3-256" role="option">MP3 - 256kbps</div>
                                            <div class="dropdown-option" data-value="audio|mp3-128" role="option">MP3 - 128kbps</div>
                                            <div class="dropdown-option" data-value="audio|mp3-64" role="option">MP3 - 64kbps</div>
                                            <div class="dropdown-option" data-value="audio|flac" role="option">FLAC</div>
                                            <div class="dropdown-option" data-value="audio|wav" role="option">WAV</div>
                                            <div class="dropdown-option" data-value="audio|m4a" role="option">M4A</div>
                                            <div class="dropdown-option" data-value="audio|opus" role="option">Opus</div>
                                            <div class="dropdown-option" data-value="audio|ogg" role="option">OGG</div>
                                        </div>
                                    </div>
                                    <script>(function(){try{var h=document.getElementById('unified-format-select');if(!h)return;var d=document.documentElement.dataset.unifiedSelection;if(d){h.value=d;var t=document.querySelector('.dropdown-selected-text');var opts=document.querySelectorAll('.dropdown-option');opts.forEach(function(o){o.classList.remove('selected');if(o.dataset.value===d){o.classList.add('selected');if(t)t.textContent=o.textContent}})}}catch(e){}})()</script>
                                </div>
                                <button type="submit" class="btn-convert">
                                    <span>{{ base.hero.convertButton }}</span>
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M5 12h14" />
                                        <path d="M12 5l7 7-7 7" />
                                    </svg>
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
                <div id="error-message" class="error-message"></div>
            </div>

            <div id="result-view" class="hidden fade-in">
                <div id="content-area"></div>
            </div>
        </div>
    </div>
</section>

<!-- Search Results Section -->
<section id="search-results-section" style="display: none;">
    <div class="container">
        <div id="search-results-container"></div>
    </div>
</section>

<!-- SEO / TEXT CONTENT -->
<section class="seo-section container">
    <div class="seo-container">
        <article class="prose">
            {%- if page.content.introTitle %}
            <h2>{{ page.content.introTitle }}</h2>
            {%- endif %}
            {%- for para in page.content.intro %}
            <p>{{ para | localizeLinks(lang) | safe }}</p>
            {%- endfor %}

            {%- for section in page.content.sections %}
            <h2 id="{{ section.id }}">{{ section.title }}</h2>
            {%- if section.paragraphs %}
            {%- for para in section.paragraphs %}
            <p>{{ para | localizeLinks(lang) | safe }}</p>
            {%- endfor %}
            {%- endif %}
            {%- if section.list %}
            <ol>
                {%- for item in section.list %}
                <li><strong>{{ item.title }}</strong><br>{{ item.text }}</li>
                {%- endfor %}
            </ol>
            {%- endif %}
            {%- endfor %}

            {%- if page.faqs and page.faqs.items %}
            <div id="faq" class="faq-section">
                <h2 class="faq-title">{{ page.faqs.title }}</h2>
                <div class="faq-grid">
                    {%- for faq in page.faqs.items %}
                    <div class="faq-item">
                        <h3 class="faq-question">{{ faq.question }}</h3>
                        <p class="faq-answer">{{ faq.answer | localizeLinks(lang) | safe }}</p>
                    </div>
                    {%- endfor %}
                </div>
            </div>
            {%- endif %}
        </article>
    </div>
</section>
