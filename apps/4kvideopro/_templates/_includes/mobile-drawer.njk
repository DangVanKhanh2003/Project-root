{%- set base = i18nBase[lang] or i18nBase['en'] -%}
{%- set langPrefix = '' if (lang == 'en' or not lang) else '/' + lang -%}
{%- set flagMap = {
  'en': 'us',
  'ar': 'sa',
  'bn': 'bd',
  'de': 'de',
  'es': 'es',
  'fr': 'fr',
  'hi': 'in',
  'id': 'id',
  'it': 'it',
  'ja': 'jp',
  'ko': 'kr',
  'my': 'mm',
  'ms': 'my',
  'pt': 'pt',
  'ru': 'ru',
  'th': 'th',
  'tr': 'tr',
  'ur': 'pk',
  'vi': 'vn'
} -%}
{%- set currentLang = lang or 'en' -%}
{%- set currentFlag = flagMap[currentLang] or 'us' -%}
<!-- MOBILE DRAWER -->
<div id="mobile-drawer" class="mobile-drawer" hidden>
    <div id="mobile-drawer-content" class="drawer-content">
        <div class="drawer-header">
            <span class="drawer-logo">{{ site.name | lower }}</span>
            <button id="close-drawer-btn" class="close-drawer-btn" aria-label="Close menu">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18" />
                    <line x1="6" y1="6" x2="18" y2="18" />
                </svg>
            </button>
        </div>
        <div class="drawer-menu">
            <a href="{{ langPrefix }}/" class="drawer-sublink">{{ base.nav.home }}</a>
            <a href="/contact" class="drawer-sublink">{{ base.nav.contact }}</a>
            <div class="drawer-divider"></div>
            <div class="drawer-lang-selector">
                <button class="drawer-lang-button">
                    <img class="lang-flag" src="/assest/flat-svg/{{ currentFlag }}.{{ 'png' if currentFlag == 'us' else 'svg' }}" alt="" aria-hidden="true"
                        loading="lazy" width="18" height="14">
                    <span>{{ currentLang | upper }}</span>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="chevron">
                        <polyline points="6 9 12 15 18 9" />
                    </svg>
                </button>
                <div class="drawer-lang-dropdown">
                    {%- for langItem in site.languages %}
                    {%- set langUrl = '/' if langItem.isDefault else '/' + langItem.code + '/' %}
                    {%- set optionFlag = flagMap[langItem.code] or 'us' %}
                    <a href="{{ langUrl }}" class="drawer-lang-option{% if lang == langItem.code or (langItem.isDefault and not lang) %} active{% endif %}">
                        <img class="lang-flag" src="/assest/flat-svg/{{ optionFlag }}.{{ 'png' if optionFlag == 'us' else 'svg' }}" alt="" aria-hidden="true"
                            loading="lazy" width="18" height="14">
                        <span>{{ langItem.name }}</span>
                    </a>
                    {%- endfor %}
                </div>
            </div>
        </div>
    </div>
</div>
