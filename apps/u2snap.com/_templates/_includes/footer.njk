{%- set base = i18nBase[lang] or i18nBase['en'] -%}
{%- set langPrefix = '' if (lang == 'en' or not lang) else '/' + lang -%}

<footer>
    <div class="container">
        <div class="footer-links" style="display: flex; justify-content: center; gap: 20px; margin-bottom: 20px; flex-wrap: wrap;">
            <a href="{{ langPrefix }}/tiktok-downloader" style="color: inherit; text-decoration: none;">{{ base.footer.links.tiktokDownloader or 'TikTok Downloader' }}</a>
            <a href="{{ langPrefix }}/facebook-downloader" style="color: inherit; text-decoration: none;">{{ base.footer.links.facebookDownloader or 'Facebook Downloader' }}</a>
            <a href="{{ langPrefix }}/instagram-downloader" style="color: inherit; text-decoration: none;">{{ base.footer.links.instagramDownloader or 'Instagram Downloader' }}</a>
            <a href="{{ langPrefix }}/twitter-downloader" style="color: inherit; text-decoration: none;">{{ base.footer.links.twitterDownloader or 'Twitter Downloader' }}</a>
            <a href="{{ langPrefix }}/soundcloud-downloader" style="color: inherit; text-decoration: none;">{{ base.footer.links.soundcloudDownloader or 'SoundCloud Downloader' }}</a>
            <a href="{{ langPrefix }}/reddit-downloader" style="color: inherit; text-decoration: none;">{{ base.footer.links.redditDownloader or 'Reddit Downloader' }}</a>
        </div>
        <div class="copyright">{{ base.footer.copyright }}</div>
    </div>
</footer>
