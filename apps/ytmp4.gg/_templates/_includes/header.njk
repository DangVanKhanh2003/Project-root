<!-- MOBILE DRAWER -->
<div id="mobile-drawer" class="mobile-drawer" hidden>
    <div id="mobile-drawer-content" class="drawer-content" role="dialog" aria-modal="true" aria-label="Mobile menu">
        <div class="drawer-header">
            <a href="{{ langPrefix }}/" class="drawer-logo" aria-label="YTMP4 home">
                <span class="drawer-logo-text">{{ base.drawer.logoText }}</span>
            </a>
            <button id="close-drawer-btn" class="drawer-close" type="button" aria-label="Close menu">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
        <div class="drawer-scroll">
            <nav class="drawer-nav" aria-label="Mobile">
                <a href="{{ langPrefix }}/" class="drawer-link">{{ base.drawer.links.youtubeToMp4 or 'YouTube to MP4' }}</a>
                <a href="{{ langPrefix }}/download-youtube-4k-video" class="drawer-link">{{ base.drawer.links.youtubeHd4k or 'Download Youtube 4k Video' }}</a>
                <a href="{{ langPrefix }}/download-youtube-1080p-video" class="drawer-link">{{ base.drawer.links.youtube1080p or 'Download Youtube 1080p Video' }}</a>
                <a href="{{ langPrefix }}/youtube-shorts-mp4" class="drawer-link">{{ base.drawer.links.shortsDownloader or 'Youtube Shorts mp4' }}</a>
                <a href="{{ langPrefix }}/youtube-video-cutter" class="drawer-link">{{ base.drawer.links.cutVideo or 'Youtube Video Cutter' }}</a>
                <a href="{{ langPrefix }}/multi-youtube-downloader" class="drawer-link">{{ base.drawer.links.playlistDownloader or 'Download Youtube Playlist' }}</a>
                <a href="{{ langPrefix }}/multi-youtube-downloader" class="drawer-link">{{ base.drawer.links.multiDownloader or 'Multi Youtube Downloader' }}</a>
                <a href="{{ langPrefix }}/download-youtube-channel" class="drawer-link">{{ base.drawer.links.channelDownloader or 'Download Youtube Channel' }}</a>
                
                <hr style="border: 0; border-top: 1px solid #eee; margin: 10px 0;">
                <a href="/about" class="drawer-link">{{ base.drawer.links.about }}</a>
                <a href="/faq" class="drawer-link">{{ base.drawer.links.faq }}</a>
                <a href="/contact" class="drawer-link">{{ base.drawer.links.contact }}</a>
                <a href="/terms-of-use" class="drawer-link">{{ base.drawer.links.terms }}</a>
                <a href="/policy" class="drawer-link">{{ base.drawer.links.privacy }}</a>
                <a href="/dmca" class="drawer-link">{{ base.drawer.links.dmca }}</a>
                <!-- Mobile License Button -->
                <div class="drawer-license-menu" data-license-button hidden aria-hidden="true">
                    <button type="button" class="drawer-license-trigger" data-license-trigger data-license-default-label="Get Premium" aria-haspopup="true" aria-expanded="false" aria-label="Get Premium options">
