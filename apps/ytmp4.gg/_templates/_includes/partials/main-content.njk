<!-- MAIN CONTENT -->
<section class="main-content">
    {% set hideHeroFeatureLinks = pageKey == 'download-youtube-playlist' or pageKey == 'download-youtube-channel' %}
    {% if not hideHeroFeatureLinks %}
    <div class="container hero-feature-links-wrap">
            <nav class="hero-feature-links hero-feature-links-desktop" aria-label="Featured tools">
                <a href="{{ langPrefix }}/download-youtube-playlist" class="hero-feature-link hero-feature-link-desktop">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M21 5H3"></path>
                        <path d="M10 12H3"></path>
                        <path d="M10 19H3"></path>
                        <path d="M15 12.003a1 1 0 0 1 1.517-.859l4.997 2.997a1 1 0 0 1 0 1.718l-4.997 2.997a1 1 0 0 1-1.517-.86z"></path>
                    </svg>
                    <span>Download Playlists</span>
                </a>
                <span class="hero-feature-divider hero-feature-divider-desktop" aria-hidden="true"></span>
                <a href="{{ langPrefix }}/multi-youtube-downloader" class="hero-feature-link hero-feature-link-desktop">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83z"></path>
                        <path d="M2 12a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 12"></path>
                        <path d="M2 17a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 17"></path>
                    </svg>
                    <span>Multiple Download</span>
                </a>
                <span class="hero-feature-divider hero-feature-divider-desktop" aria-hidden="true"></span>
                <a href="{{ langPrefix }}/multi-youtube-downloader" class="hero-feature-link hero-feature-link-desktop">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M9 12a3 3 0 1 0 3 3V6h2a3 3 0 0 0 3 3"></path>
                    </svg>
                    <span>Download TikTok</span>
                </a>
            </nav>
            <nav class="hero-feature-links hero-feature-links-mobile" aria-label="Featured tools mobile">
                <button type="button" class="hero-feature-link hero-feature-link-mobile" data-href="{{ langPrefix }}/download-youtube-playlist">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M21 5H3"></path>
                        <path d="M10 12H3"></path>
                        <path d="M10 19H3"></path>
                        <path d="M15 12.003a1 1 0 0 1 1.517-.859l4.997 2.997a1 1 0 0 1 0 1.718l-4.997 2.997a1 1 0 0 1-1.517-.86z"></path>
                    </svg>
                    <span>Download Playlists</span>
                </button>
                <button type="button" class="hero-feature-link hero-feature-link-mobile" data-href="{{ langPrefix }}/multi-youtube-downloader">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83z"></path>
                        <path d="M2 12a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 12"></path>
                        <path d="M2 17a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 17"></path>
                    </svg>
                    <span>Multiple Download</span>
                </button>
            </nav>
    </div>
    {% endif %}

    <div class="container">
            <div class=" main-content-card">
        {% for section in page.content.sections %}
        <div class="content-section">
            <h2>{{ section.h2 }}</h2>

            {# --- Simple paragraphs --- #}
            {% if section.p %}
                {% for para in section.p %}
                <p>{{ para | localizeLinks(langPrefix) | safe }}</p>
                {% endfor %}
            {% endif %}

            {# --- Ordered list (e.g. how-to steps) --- #}
            {% if section.ol %}
            <ol>
                {% for item in section.ol %}
                <li>
                    <h3>{{ item.h3 }}</h3>
                    {% for para in item.p %}
                    <p>{{ para | localizeLinks(langPrefix) | safe }}</p>
                    {% endfor %}
                </li>
                {% endfor %}
            </ol>
            {% endif %}

            {# --- Unordered list (e.g. features, FAQs, comparisons) --- #}
            {% if section.ul %}
            <ul>
                {% for item in section.ul %}
                <li>
                    <h3>{{ item.h3 }}</h3>
                    {% for para in item.p %}
                    <p>{{ para | localizeLinks(langPrefix) | safe }}</p>
                    {% endfor %}
                </li>
                {% endfor %}
            </ul>
            {% endif %}
        </div>
        {% endfor %}
    </div>
    </div>

</section>
