{%- set base = i18nBase[lang] or i18nBase['en'] -%}
{%- set langPrefix = '' if (lang == 'en' or not lang) else '/' + lang -%}

<footer>
    <div class="container">
        <div class="footer-links" style="display: flex; justify-content: center; gap: 20px; margin-bottom: 20px; flex-wrap: wrap;">
            <a href="{{ langPrefix }}/download-youtube-4k-video" style="color: inherit; text-decoration: none;">{{ base.footer.linksRow1.youtubeHd4k or 'Download Youtube 4k Video' }}</a>
            <a href="{{ langPrefix }}/download-youtube-1080p-video" style="color: inherit; text-decoration: none;">{{ base.footer.linksRow1.youtube1080p or 'Download Youtube 1080p Video' }}</a>
            <a href="{{ langPrefix }}/youtube-shorts-mp4" style="color: inherit; text-decoration: none;">{{ base.footer.linksRow1.shortsDownloader or 'Youtube Shorts mp4' }}</a>
            <a href="{{ langPrefix }}/youtube-video-cutter" style="color: inherit; text-decoration: none;">{{ base.footer.linksRow1.cutVideo or 'Youtube Video Cutter' }}</a>
            <a href="{{ langPrefix }}/download-youtube-playlist" style="color: inherit; text-decoration: none;">{{ base.footer.linksRow1.playlistDownloader or 'Download Youtube Playlist' }}</a>
            <a href="{{ langPrefix }}/multi-youtube-downloader" style="color: inherit; text-decoration: none;">{{ base.footer.linksRow1.multiDownloader or 'Multi Youtube Downloader' }}</a>
            <a href="{{ langPrefix }}/download-youtube-channel" style="color: inherit; text-decoration: none;">{{ base.footer.linksRow1.channelDownloader or 'Download Youtube Channel' }}</a>
        </div>
        <div class="footer-links" style="display: flex; justify-content: center; gap: 20px; margin-bottom: 20px; flex-wrap: wrap;">
            <a href="/about" style="color: inherit; text-decoration: none;">{{ base.footer.linksRow2.about }}</a>
            <a href="/contact" style="color: inherit; text-decoration: none;">{{ base.footer.linksRow2.contact }}</a>
            <a href="/terms-of-use" style="color: inherit; text-decoration: none;">{{ base.footer.linksRow2.terms }}</a>
            <a href="/policy" style="color: inherit; text-decoration: none;">{{ base.footer.linksRow2.privacyPolicy }}</a>
            <a href="/dmca" style="color: inherit; text-decoration: none;">{{ base.footer.linksRow2.dmca }}</a>
            <a href="/faq" style="color: inherit; text-decoration: none;">{{ base.footer.linksRow2.faq }}</a>
        </div>
        <div class="copyright">{{ base.footer.copyright }}</div>
    </div>
</footer>
