                        </path>
                    </svg>
                    <h3>{{ page.features.items[3].title }}</h3>
                    <p>{{ page.features.items[3].description }}</p>
                </div>
            </div>
            <div class="col-sm-4 d-flex">
                <div class="y2mate-features-pro">
                    <svg xmlns="http://www.w3.org/2000/svg" width="50" height="50" fill="currentColor" class="bi bi-badge-hd"
                        viewBox="0 0 16 16">
