{#- Calculate language prefix for internal links -#}
{%- set langPrefix = '' if (lang == 'en' or not lang) else '/' + lang -%}
<footer class="footer">
    <p>{{ base.footer.copyright }}</p>
    <ul class="footer_nav">
        <li class="fnav-menu">
            <a href="{{ langPrefix }}/youtube-to-mp4">{{ base.nav.youtubeToMp4 }}</a>
        </li>
        <li class="fnav-menu">
            <a href="{{ langPrefix }}/youtube-to-mp3">{{ base.nav.youtubeToMp3 }}</a>
        </li>
        <li class="fnav-menu">
            <a href="{{ langPrefix }}/youtube-short-downloader">{{ base.nav.youtubeShorts }}</a>
        </li>
        <li class="fnav-menu">
            <a href="/about-us">{{ base.footer.about }}</a>
        </li>
        <li class="fnav-menu">
            <a href="/contact">{{ base.footer.contact }}</a>
        </li>
        <li class="fnav-menu">
            <a href="/terms-condition">{{ base.footer.terms }}</a>
        </li>
        <li class="fnav-menu">
            <a href="/privacy-policy">{{ base.footer.privacy }}</a>
        </li>
    </ul>
</footer>
