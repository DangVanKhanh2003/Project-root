{% set i18n = i18nData[lang or 'en'] %}
{% set seo = i18n.seo[seoKey or 'homepage'] %}
<!DOCTYPE html>
<html lang="{{ i18n.meta.lang }}" dir="{{ i18n.meta.dir }}">

<head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="robots" content="index, follow">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">
    <meta charset="UTF-8">

    <!-- SEO Metadata -->
    <title>{{ seo.title }}</title>
    <meta name="description" content="{{ seo.description }}">
    <link rel="canonical" href="{{ site.url }}{{ page.url }}">

    <!-- Schema.org markup -->
    <meta itemprop="name" content="{{ seo.schemaName }}" />
    <meta itemprop="description" content="{{ seo.schemaDescription }}">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Y2MatePro" />
    <meta property="og:locale" content="{{ i18n.meta.locale }}" />
    <meta property="og:title" content="{{ seo.ogTitle }}" />
    <meta property="og:description" content="{{ seo.ogDescription }}" />
    <meta property="og:image" content="{{ site.url }}/logo.png" />
    <meta property="og:url" content="{{ site.url }}{{ page.url }}" />

    <!-- Security -->
    <meta http-equiv="Content-Security-Policy" content="upgrade-insecure-requests">

    <!-- Favicons -->
    <link rel="icon" href="/favicon.png">
    <link type="image/png" sizes="16x16" rel="icon" href="/favicon1616.png">
    <link type="image/png" sizes="32x32" rel="icon" href="/favicon3232.png">
    <link type="image/png" sizes="48x48" rel="icon" href="/favicon4848.png">
    <link type="image/png" sizes="96x96" rel="icon" href="/favicon9696.png">

    <!-- Theme Color -->
    <meta name="theme-color" content="#c10841">
    <meta name="color-scheme" content="light">

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-ZWPL9SR6P6"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag() {
            dataLayer.push(arguments);
        }
        gtag('js', new Date());
        gtag('config', 'G-ZWPL9SR6P6');
    </script>

    <!-- Critical CSS imported via Vite -->
    <script type="module" src="/src/main.ts"></script>
</head>

<body>
    {% include "header.njk" %}

    {{ content | safe }}

    {% include "footer.njk" %}

    <!-- Conversion Modal Wrapper -->
    <div id="progressBarWrapper"></div>
</body>

</html>
