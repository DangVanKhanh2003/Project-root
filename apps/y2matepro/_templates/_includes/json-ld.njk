{#- JSON-LD Structured Data for SEO -#}
{%- set isHomePage = (pageKey == 'index') -%}
{%- set hasInstructions = pageData.instructions and pageData.instructions.steps -%}
{%- set hasFaqs = pageData.faqs and pageData.faqs.items -%}

{#- Organization (shared across all schemas) -#}
{%- set organization = {
  "@type": "Organization",
  "name": "Y2mate",
  "url": site.url,
  "logo": site.url + "/logo.png",
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "y2matepro@gmail.com",
    "contactType": "customer service"
  }
} -%}

{#- Build canonical URL -#}
{%- set cleanUrl = page.url | replace('/index.html', '/') | replace('.html', '') -%}
{%- set canonicalUrl = site.url + cleanUrl -%}

<script type="application/ld+json">
{%- if isHomePage %}
{#- === HOMEPAGE: WebSite Schema === -#}
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "name": "Y2mate",
      "url": "{{ site.url }}",
      "description": "{{ seo.description | jsonString | safe }}",
      "inLanguage": "{{ lang or 'en' }}",
      "publisher": {{ organization | dump | safe }}
    },
    {{ organization | dump | safe }}
    {%- if hasFaqs %},
    {
      "@type": "FAQPage",
      "mainEntity": [
        {%- for item in pageData.faqs.items %}
        {
          "@type": "Question",
          "name": "{{ item.question | jsonString | safe }}",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "{{ item.answer | jsonString | safe }}"
          }
        }{%- if not loop.last %},{% endif %}
        {%- endfor %}
      ]
    }
    {%- endif %}
    {%- if hasInstructions %},
    {
      "@type": "HowTo",
      "name": "{{ pageData.instructions.title | jsonString | safe }}",
      "step": [
        {%- for step in pageData.instructions.steps %}
        {
          "@type": "HowToStep",
          "position": {{ loop.index }},
          "text": "{{ step | jsonString | safe }}"
        }{%- if not loop.last %},{% endif %}
        {%- endfor %}
      ]
    }
    {%- endif %}
  ]
}
{%- else %}
{#- === TOOL PAGES: WebApplication Schema === -#}
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Y2mate",
      "url": "{{ canonicalUrl }}",
      "description": "{{ seo.schemaDescription | jsonString | safe }}",
      "applicationCategory": "MultimediaApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "inLanguage": "{{ lang or 'en' }}",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "publisher": {{ organization | dump | safe }}
    }
    {%- if hasFaqs %},
    {
      "@type": "FAQPage",
      "mainEntity": [
        {%- for item in pageData.faqs.items %}
        {
          "@type": "Question",
          "name": "{{ item.question | jsonString | safe }}",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "{{ item.answer | jsonString | safe }}"
          }
        }{%- if not loop.last %},{% endif %}
        {%- endfor %}
      ]
    }
    {%- endif %}
    {%- if hasInstructions %},
    {
      "@type": "HowTo",
      "name": "{{ pageData.instructions.title | jsonString | safe }}",
      "step": [
        {%- for step in pageData.instructions.steps %}
        {
          "@type": "HowToStep",
          "position": {{ loop.index }},
          "text": "{{ step | jsonString | safe }}"
        }{%- if not loop.last %},{% endif %}
        {%- endfor %}
      ]
    }
    {%- endif %}
  ]
}
{%- endif %}
</script>
