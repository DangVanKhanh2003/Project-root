<header class="nav-header">
    <div class="container">
        <div class="nav_head">
            <div class="navbar-logo">
                <a href="{% if lang == 'en' %}/{% else %}/{{ lang }}/{% endif %}">
                    <img height="46px" width="46px" src="/logo.png" alt="Y2MatePro logo">
                    <span class="logo-name">{{ i18n.meta.siteName }}</span>
                </a>
            </div>
            <button type="button" class="navbar-toggler" id="mobileMenuToggle">
                <span class="toggle-icon"></span>
                <span class="toggle-icon"></span>
                <span class="toggle-icon"></span>
            </button>
        </div>
        <div class="header-menu">
            <ul class="menu-navbar">
                <li class="navbar">
                    <a href="{% if lang == 'en' %}/{% else %}/{{ lang }}/{% endif %}">{{ i18n.nav.home }}</a>
                </li>
                <li class="navbar">
                    <a href="{% if lang == 'en' %}/youtube-to-mp4{% else %}/{{ lang }}/youtube-to-mp4{% endif %}">{{ i18n.nav.youtubeToMp4 }}</a>
                </li>
                <li class="navbar">
                    <a href="{% if lang == 'en' %}/youtube-to-mp3{% else %}/{{ lang }}/youtube-to-mp3{% endif %}">{{ i18n.nav.youtubeToMp3 }}</a>
                </li>
                <li class="navbar language">
                    <a href="javascript:void(0);">
                        {{ i18n.nav.language }}<span class="shape"></span>
                    </a>
                    <div class="dropdown-menu">
                        <ul class="lang-menu">
                            <li>
                                <a data-lang="en" href="/">English</a>
                            </li>
                        </ul>
                    </div>
                </li>
            </ul>
        </div>

        <!-- Mobile Menu Overlay -->
        <div class="mobile-menu-overlay" id="mobileMenuOverlay">
            <div class="mobile-menu-content">
                <div class="mobile-header-top">
                    <a href="{% if lang == 'en' %}/{% else %}/{{ lang }}/{% endif %}">
                        <div class="mobile-logo">
                            <img height="36px" width="36px" src="/logo.png" alt="Y2MatePro logo">
                            <span class="logo-name">Y2matePro</span>
                        </div>
                    </a>
                    <button type="button" class="mobile-close-btn" id="mobileCloseBtn">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                    </button>
                </div>
                <nav class="mobile-nav">
                    <ul class="mobile-menu">
                        <li><a href="{% if lang == 'en' %}/{% else %}/{{ lang }}/{% endif %}">{{ i18n.nav.home }}</a></li>
                        <li><a href="{% if lang == 'en' %}/youtube-to-mp4{% else %}/{{ lang }}/youtube-to-mp4{% endif %}">{{ i18n.nav.youtubeToMp4 }}</a></li>
                        <li><a href="{% if lang == 'en' %}/youtube-to-mp3{% else %}/{{ lang }}/youtube-to-mp3{% endif %}">{{ i18n.nav.youtubeToMp3 }}</a></li>
                        <li><a href="{% if lang == 'en' %}/youtube-music-downloader{% else %}/{{ lang }}/youtube-music-downloader{% endif %}">{{ i18n.nav.youtubeMusicDownloader }}</a></li>
                        <li><a href="{% if lang == 'en' %}/youtube-to-mp3-320kbps-converter{% else %}/{{ lang }}/youtube-to-mp3-320kbps-converter{% endif %}">{{ i18n.nav.youtubeMp3320 }}</a></li>
                        <li><a href="{% if lang == 'en' %}/youtube-to-wav-converter{% else %}/{{ lang }}/youtube-to-wav-converter{% endif %}">{{ i18n.nav.youtubeToWav }}</a></li>
                        <li><a href="{% if lang == 'en' %}/youtube-to-ogg-converter{% else %}/{{ lang }}/youtube-to-ogg-converter{% endif %}">{{ i18n.nav.youtubeToOgg }}</a></li>
                        <li><a href="{% if lang == 'en' %}/youtube-to-opus-converter{% else %}/{{ lang }}/youtube-to-opus-converter{% endif %}">{{ i18n.nav.youtubeToOpus }}</a></li>
                        <li><a href="{% if lang == 'en' %}/youtube-short-downloader{% else %}/{{ lang }}/youtube-short-downloader{% endif %}">{{ i18n.nav.youtubeShorts }}</a></li>
                    </ul>
                </nav>
            </div>
        </div>
        <!-- End Mobile Menu Overlay -->
    </div>
</header>
