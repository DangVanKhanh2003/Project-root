                            </svg>
                        </span>
                        <span>Get Premium</span>
                        <svg class="license-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                            <path d="M6 9l6 6 6-6" />
                        </svg>
                    </button>
                    <div class="license-dropdown" data-license-dropdown>
                        <!-- Items rendered dynamically via JS -->
                    </div>
                </div>

                <div class="lang-selector">
                    <button class="lang-button" type="button" aria-label="{{ base.langSelector.buttonLabel }}">
                        <span>{{ (lang or 'en') | upper }}</span>
                        <svg class="lang-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2">
                            <path d="M6 9l6 6 6-6" />
                        </svg>
                    </button>
                    <div class="lang-dropdown" role="menu" aria-label="Languages">
                        <div class="lang-dropdown-scroll">
                            {%- set singleLangPages = ['about', 'contact', 'dmca', 'faq', 'policy', 'terms-of-use'] -%}
                            {%- for langItem in site.languages %}
                            {%- if langItem.isDefault %}
                                {%- set langUrl = '/' if pageSlug == '' else '/' + pageSlug %}
                            {%- else %}
                                {%- if pageKey in singleLangPages %}
                                    {%- set langUrl = '/' + langItem.code + '/' %}
                                {%- else %}
                                    {%- set langUrl = '/' + langItem.code + '/' if pageSlug == '' else '/' + langItem.code + '/' + pageSlug %}
                                {%- endif %}
                            {%- endif %}
                            <a href="{{ langUrl }}" class="lang-option{% if langItem.code == lang %} active{% endif %}" role="menuitem">
                                <img class="lang-flag" src="/assest/flat-svg/{{ langItem.flag }}" alt="{{ langItem.name }}" aria-hidden="true"
                                    loading="lazy" width="18" height="14">
                                <span>{{ langItem.name }}</span>
                            </a>
                            {%- endfor %}
                        </div>
                    </div>
                </div>
                <button
                    type="button"
                    class="theme-toggle-btn"
                    aria-label="Toggle theme"
                    onclick="setTheme(document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark')">
                    <svg class="theme-toggle-icon icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                        <circle cx="12" cy="12" r="4"></circle>
                        <path d="M12 2v2"></path>
                        <path d="M12 20v2"></path>
                        <path d="M4.93 4.93l1.41 1.41"></path>
                        <path d="M17.66 17.66l1.41 1.41"></path>
                        <path d="M2 12h2"></path>
                        <path d="M20 12h2"></path>
                        <path d="M6.34 17.66l-1.41 1.41"></path>
                        <path d="M19.07 4.93l-1.41 1.41"></path>
                    </svg>
                    <svg class="theme-toggle-icon icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3c0 0 0 0 0 0a7 7 0 0 0 9.79 9.79z"></path>
                    </svg>
                </button>
            </nav>
            <button id="mobile-menu-btn" class="mobile-menu-btn" type="button" aria-label="Open menu">
                <span class="mobile-menu-bars" aria-hidden="true"></span>
            </button>
        </div>
    </div>
</header>

<!-- MOBILE DRAWER -->
