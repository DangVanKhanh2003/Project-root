{%- set base = i18nBase[lang] or i18nBase['en'] -%}
{%- set langPrefix = '' if (lang == 'en' or not lang) else '/' + lang -%}
{%- set pageSlug = '' if pageKey == 'index' else pageKey -%}

<!-- HEADER -->
<header class="site-header">
    <div class="container">
        <div class="header-inner">
            <a href="{{ langPrefix }}/" class="header-logo" aria-label="Y2Save home">
                <span class="header-logo-text">Y2Save</span>
            </a>
            <nav class="header-nav" aria-label="Primary">
                <!-- License Button -->
                <div class="license-menu" data-license-button hidden aria-hidden="true">
                    <button type="button" class="license-button" data-license-trigger data-license-default-label="Get Premium" aria-haspopup="true" aria-expanded="false" aria-label="Get Premium options">
                        <span class="license-icon" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 32 32" version="1.1">
                                <title>gift</title>
