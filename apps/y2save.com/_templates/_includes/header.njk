    <div id="mobile-drawer-content" class="drawer-content" role="dialog" aria-modal="true" aria-label="Mobile menu">
        <div class="drawer-header">
            <a href="{{ langPrefix }}/" class="drawer-logo" aria-label="Y2Save home">
                <svg class="drawer-logo-icon" xmlns="http://www.w3.org/2000/svg" viewBox="164 259 709 405" aria-hidden="true">
