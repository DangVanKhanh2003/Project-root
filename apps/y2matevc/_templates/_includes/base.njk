{%- set base = i18nBase[lang] or i18nBase['en'] -%}
{%- set pageData = i18nPages[pageKey or 'index'][lang or 'en'] -%}
{%- set seo = pageData.seo -%}
{#- Language-specific configs for multilingual SEO -#}
{%- set localeMap = {
  en: 'en_US',
  vi: 'vi_VN'
} -%}
{%- set locale = localeMap[lang] or 'en_US' -%}
{#- RTL languages -#}
{%- set rtlLanguages = ['ar', 'ur'] -%}
<!DOCTYPE html>
<html lang="{{ lang or 'en' }}"{% if lang in rtlLanguages %} dir="rtl"{% endif %}>

<head>
    <meta name="robots" content="index, follow">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">
    <meta charset="UTF-8">

    <!-- SEO Metadata -->
    <title>{{ seo.title }}</title>
    <meta name="description" content="{{ seo.description }}">
    {% set cleanUrl = page.url | replace('/index.html', '/') | replace('.html', '') %}
    <link rel="canonical" href="{{ site.url }}{{ cleanUrl }}">

    <!-- hreflang tags for multilingual SEO -->
    {%- set pageSlug = '' if pageKey == 'index' else pageKey -%}
    {%- for langItem in site.languages %}
    {%- if langItem.isDefault %}
    {%- set altUrl = '/' if pageSlug == '' else '/' + pageSlug %}
    {%- else %}
    {%- set altUrl = '/' + langItem.code + '/' if pageSlug == '' else '/' + langItem.code + '/' + pageSlug %}
    {%- endif %}
    <link rel="alternate" hreflang="{{ langItem.code }}" href="{{ site.url }}{{ altUrl }}" />
    {%- endfor %}
    <link rel="alternate" hreflang="x-default" href="{{ site.url }}{{ '/' if pageSlug == '' else '/' + pageSlug }}" />

    <!-- Schema.org markup -->
    <meta itemprop="name" content="{{ seo.schemaName }}" />
    <meta itemprop="description" content="{{ seo.schemaDescription }}">
    <meta itemprop="inLanguage" content="{{ lang or 'en' }}" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Y2Mate" />
    <meta property="og:locale" content="{{ locale }}" />
    <meta property="og:title" content="{{ seo.ogTitle }}" />
    <meta property="og:description" content="{{ seo.ogDescription }}" />
    <meta property="og:image" content="{{ site.url }}/favicon-512x512.png" />
    <meta property="og:url" content="{{ site.url }}{{ page.url | replace('.html', '') | replace('/index', '/') }}" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content="{{ site.url }}{{ page.url | replace('.html', '') | replace('/index', '/') }}">
    <meta name="twitter:title" content="{{ seo.ogTitle or seo.title }}">
    <meta name="twitter:description" content="{{ seo.ogDescription or seo.description }}">
    <meta name="twitter:image" content="{{ site.url }}/favicon-512x512.png">

    <!-- Favicons -->
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/favicon.png" type="image/png">
    <link type="image/png" sizes="16x16" rel="icon" href="/favicon1616.png">
    <link type="image/png" sizes="32x32" rel="icon" href="/favicon3232.png">
    <link type="image/png" sizes="48x48" rel="icon" href="/favicon4848.png">
    <link type="image/png" sizes="96x96" rel="icon" href="/favicon9696.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">

    <!-- Theme Color -->
    <meta name="theme-color" content="#c10841">
    <meta name="color-scheme" content="light">

    <!-- Google Analytics: Lazy loaded via analytics-loader.ts for better performance -->

    <!-- Critical: Set format and auto-submit preferences before render to prevent FOUC -->
    <script>(function(){var f='mp4',a='false';try{var p=JSON.parse(localStorage.getItem('y2mate_format_preferences'));if(p&&p.selectedFormat)f=p.selectedFormat;var s=localStorage.getItem('y2mate_auto_submit');if(s)a=s;}catch(e){}document.documentElement.dataset.format=f;document.documentElement.dataset.autoSubmit=a;})()</script>

    <!-- Critical: Hide auto-submit tooltip before CSS loads -->
    <style>
        .custom-tooltip {
            opacity: 0;
            visibility: hidden;
        }
    </style>

    <!-- Critical: Prevent default form submit before app init (avoid /search 404) -->
    <script>(function(){document.addEventListener('submit',function(event){var target=event.target;if(target&&target.id==='downloadForm'){event.preventDefault();}},true);})();</script>

    <!-- Critical CSS imported via Vite -->
    <script type="module" src="/src/main.ts"></script>

    <!-- JSON-LD Structured Data -->
    {% include "json-ld.njk" %}
</head>

<body>
    {% include "header.njk" %}

    <main>
    {{ content | safe }}
    </main>

    {% include "footer.njk" %}

    <!-- Conversion Modal Wrapper -->
    <div id="progressBarWrapper"></div>

    <!-- Ko-fi Support Widget -->
    <script src='https://storage.ko-fi.com/cdn/scripts/overlay-widget.js'></script>
    <script>
      kofiWidgetOverlay.draw('metaconvert', {
        'type': 'floating-chat',
        'floating-chat.donateButton.text': 'Support me',
        'floating-chat.donateButton.background-color': '#00b9fe',
        'floating-chat.donateButton.text-color': '#fff'
      });
    </script>
</body>

</html>
