{
  "name": "downloader-monorepo",
  "version": "1.0.0",
  "description": "TypeScript Monorepo for Downloader Project",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:all": "node scripts/dev-all.cjs",
    "dev:ytmp3": "pnpm --filter ytmp3-clone-3 dev",
    "build": "vite build",
    "build:no-critical": "vite build",
    "preview": "vite preview",
    "build:packages": "pnpm -r --filter \"./packages/**\" run build",
    "lint": "pnpm -r run lint",
    "type-check": "pnpm -r exec tsc --noEmit",
    "clean": "pnpm -r run clean",
    "test:seo": "tsx skills/test-seo/src/index.ts",
    "test:seo:all": "node scripts/test-seo-all.js",
    "deploy": "powershell -ExecutionPolicy Bypass -File ./deploy-menu.ps1",
    "deploy:bash": "bash ./deploy-menu.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DangVanKhanh2003/project3.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/DangVanKhanh2003/project3/issues"
  },
  "homepage": "https://github.com/DangVanKhanh2003/project3#readme",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "critical": "^7.2.1",
    "critters": "^0.0.23",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.0.0",
    "minify-html-literals": "^1.3.5",
    "prettier": "^3.0.0",
    "rollup-plugin-critical": "^1.0.15",
    "rollup-plugin-minify-html-literals": "^1.2.6",
    "sharp": "^0.34.5",
    "terser": "^5.44.0",
    "tsx": "^4.20.6",
    "typescript": "^5.3.3",
    "vite": "^7.1.10",
    "vite-plugin-purgecss": "^0.2.13",
    "vite-plugin-static-copy": "^3.1.4"
  },
  "dependencies": {
    "firebase": "^12.8.0"
  }
}